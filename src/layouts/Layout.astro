---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import { ClientRouter } from 'astro:transitions';
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'LVI-suunnittelu Helsinki, Tampere, Jyväskylä | Vattu Oy',
  description = 'LVI-suunnittelija Uudellamaalla, Pirkanmaalla ja Keski-Suomessa. KVV, IV ja FISE-pätevyydet. Energiatodistukset ja -selvitykset. Pyydä ilmainen tarjous.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <ClientRouter />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fi_FI" />
    <meta name="theme-color" content="#F4F0E8" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://vattu.fi/#business",
          "name": "LVI-insinööritoimisto Vattu Oy",
          "url": "https://vattu.fi",
          "email": "oskari@vattu.fi",
          "telephone": "+358407656096",
          "vatID": "FI35626898",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Leineläntie 15 H 39",
            "postalCode": "01340",
            "addressLocality": "Vantaa",
            "addressCountry": "FI"
          },
          "areaServed": [
            { "@type": "State", "name": "Uusimaa" },
            { "@type": "State", "name": "Pirkanmaa" },
            { "@type": "State", "name": "Keski-Suomi" }
          ],
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "LVI-suunnittelupalvelut",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "LVI-suunnittelu" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Energiatodistus" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Energiaselvitys" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Patteriverkoston tasapainotus" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Olosuhde- ja energiasimulointi" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Moduulirakentaminen LVI" } }
            ]
          },
          "employee": {
            "@type": "Person",
            "name": "Oskari Vattu",
            "jobTitle": "LVI-suunnittelija, DI-opiskelija",
            "sameAs": "https://www.linkedin.com/in/oskari-vattu-517936280/",
            "hasCredential": [
              {
                "@type": "EducationalOccupationalCredential",
                "credentialCategory": "license",
                "name": "Kiinteistön vesi- ja viemärilaitteiston suunnittelija, tavanomainen (KVV)",
                "recognizedBy": { "@type": "Organization", "name": "FISE Oy" }
              },
              {
                "@type": "EducationalOccupationalCredential",
                "credentialCategory": "license",
                "name": "Ilmanvaihdon suunnittelija, tavanomainen (IV)",
                "recognizedBy": { "@type": "Organization", "name": "FISE Oy" }
              },
              {
                "@type": "EducationalOccupationalCredential",
                "credentialCategory": "license",
                "name": "Energiatodistuksen laatija, ylempi taso (FISE)",
                "recognizedBy": { "@type": "Organization", "name": "FISE Oy" }
              }
            ]
          },
          "sameAs": [
            "https://www.linkedin.com/in/oskari-vattu-517936280/",
            "https://www.finder.fi/LVI-suunnittelu/LVI-insin%C3%B6%C3%B6ritoimisto+Vattu+Oy/Vantaa/yhteystiedot/4233293"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://vattu.fi/#website",
          "url": "https://vattu.fi",
          "name": "LVI-insinööritoimisto Vattu Oy",
          "inLanguage": "fi",
          "publisher": { "@id": "https://vattu.fi/#business" }
        }
      ]
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Anuphan:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-body text-base bg-cream text-[#1A1A1A]">
    <!-- Grain overlay — fixed, pointerevents-none -->
    <div class="fixed inset-0 z-[60] pointer-events-none opacity-[0.032]" style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.75%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22200%22 height=%22200%22 filter=%22url(%23n)%22 opacity=%221%22/></svg>');background-size:200px 200px;"></div>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-forest focus:text-white focus:px-4 focus:py-2 focus:text-sm">Siirry sisältöön</a>
    <Navbar />
    <main id="main-content">
    <slot />
    </main>

    <!-- ── MOBIILINAVIGAATIO (global) ── -->

    <!-- Overlay -->
    <div id="mob-overlay" class="lg:hidden fixed inset-0 z-[48] bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300"></div>

    <!-- Slide-up drawer -->
    <div id="mob-drawer" role="dialog" aria-modal="true" aria-label="Valikko" class="lg:hidden fixed left-0 right-0 z-[49] bg-forest backdrop-blur-xl rounded-t-2xl ring-1 ring-white/10 shadow-[0_-8px_40px_rgba(0,0,0,0.4)] translate-y-full transition-transform duration-300 ease-out" style="bottom: calc(3.5rem + env(safe-area-inset-bottom)); overscroll-behavior: contain;">
      <div class="px-6 pt-5 pb-6">
        <!-- Handle -->
        <div class="w-8 h-0.5 bg-white/20 mx-auto mb-6 rounded-full"></div>

        <!-- Kaikki palvelut -->
        <a href="/#palvelut" class="flex items-center justify-between w-full font-body text-sm text-white px-2 py-2.5 mb-5 border-b border-white/10 hover:text-white/70 transition-colors">
          Kaikki palvelut
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>

        <!-- Energia -->
        <p class="font-body text-[9px] tracking-[0.2em] uppercase text-white/25 mb-3">Energia</p>
        <div class="space-y-0.5 mb-5">
          <a href="/energiaselvitys" class="block font-body text-sm text-white/60 hover:text-white px-2 py-2 rounded-lg hover:bg-white/5 transition-colors">Energiaselvitys</a>
          <a href="/energiaselvitys-hinta" class="block font-body text-sm text-white/60 hover:text-white px-2 py-2 rounded-lg hover:bg-white/5 transition-colors">Energiaselvityksen hinta</a>
          <a href="/energiatodistus-hinta" class="block font-body text-sm text-white/60 hover:text-white px-2 py-2 rounded-lg hover:bg-white/5 transition-colors">Energiatodistuksen hinta</a>
        </div>

        <!-- Suunnittelu -->
        <div class="border-t border-white/8 pt-5">
          <p class="font-body text-[9px] tracking-[0.2em] uppercase text-white/25 mb-3">Suunnittelu</p>
          <div class="space-y-0.5">
            <a href="/lvi-suunnittelu-hinta" class="block font-body text-sm text-white/60 hover:text-white px-2 py-2 rounded-lg hover:bg-white/5 transition-colors">LVI-suunnittelun hinta</a>
            <a href="/patteriverkoston-tasapainotus" class="block font-body text-sm text-white/60 hover:text-white px-2 py-2 rounded-lg hover:bg-white/5 transition-colors">Patteriverkoston tasapainotus</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom nav bar -->
    <nav class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-forest/95 backdrop-blur-sm border-t border-white/10" style="padding-bottom: env(safe-area-inset-bottom)">
      <div class="grid grid-cols-3">
        <a href="/" class="flex flex-col items-center gap-1 py-3 px-2 text-white/40 hover:text-white transition-colors duration-200 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-1 focus-visible:ring-offset-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.5 1.5 0 012.092 0L22.25 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          <span class="font-body text-[9px] tracking-[0.12em] uppercase">Etusivu</span>
        </a>
        <button id="mob-menu-btn" aria-expanded="false" aria-controls="mob-drawer" class="flex flex-col items-center gap-1 py-3 px-2 text-white/40 hover:text-white transition-colors duration-200 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-1 focus-visible:ring-offset-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
          </svg>
          <span class="font-body text-[9px] tracking-[0.12em] uppercase">Palvelut</span>
        </button>
        <a href="#yhteydenotto" class="flex flex-col items-center gap-1 py-3 px-2 text-white/40 hover:text-white transition-colors duration-200 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-1 focus-visible:ring-offset-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3h10.5A2.25 2.25 0 0119.5 5.25v13.5A2.25 2.25 0 0117.25 21H6.75A2.25 2.25 0 014.5 18.75V5.25A2.25 2.25 0 016.75 3zM9 7.5h6M9 12h6m-6 4.5h3" />
          </svg>
          <span class="font-body text-[9px] tracking-[0.12em] uppercase">Yhteys</span>
        </a>
      </div>
    </nav>

    <script>
      function initDrawer() {
        const btn = document.getElementById('mob-menu-btn');
        const drawer = document.getElementById('mob-drawer');
        const overlay = document.getElementById('mob-overlay');

        const openDrawer = () => {
          drawer?.classList.remove('translate-y-full');
          overlay?.classList.remove('opacity-0', 'pointer-events-none');
          overlay?.classList.add('opacity-100');
          btn?.setAttribute('aria-expanded', 'true');
        };
        const closeDrawer = () => {
          drawer?.classList.add('translate-y-full');
          overlay?.classList.remove('opacity-100');
          overlay?.classList.add('opacity-0', 'pointer-events-none');
          btn?.setAttribute('aria-expanded', 'false');
        };

        btn?.addEventListener('click', () => {
          drawer?.classList.contains('translate-y-full') ? openDrawer() : closeDrawer();
        });
        overlay?.addEventListener('click', closeDrawer);
        drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));
      }

      document.addEventListener('astro:page-load', initDrawer);
    </script>

    <footer class="bg-forest text-white pt-10 pb-24 lg:py-12">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">

          <!-- Yritystiedot -->
          <div>
            <p class="font-heading text-base mb-4">LVI-insinööritoimisto Vattu Oy</p>
            <div class="font-body text-sm text-white/60 space-y-1">
              <p><a href="mailto:oskari@vattu.fi" class="hover:text-white transition-colors">oskari@vattu.fi</a></p>
              <p><a href="tel:+358407656096" class="hover:text-white transition-colors">040 7656 096</a></p>
              <p class="flex items-center gap-2">
                Y-tunnus 3562689-8
                <a
                  href="https://www.finder.fi/LVI-suunnittelu/LVI-insin%C3%B6%C3%B6ritoimisto+Vattu+Oy/Vantaa/yhteystiedot/4233293"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-body text-[10px] tracking-[0.12em] uppercase text-white/30 hover:text-white/70 border border-white/15 px-2 py-0.5 transition-colors"
                >
                  Finder
                </a>
              </p>
            </div>
          </div>

          <!-- Sivut -->
          <div>
            <p class="font-body text-[10px] tracking-[0.2em] uppercase text-white/25 mb-3">Sivut</p>
            <div class="flex flex-col gap-1.5">
              <a href="/" class="font-body text-sm text-white/50 hover:text-white transition-colors">Etusivu</a>
              <a href="/uusimaa" class="font-body text-sm text-white/50 hover:text-white transition-colors">Uusimaa</a>
              <a href="/pirkanmaa" class="font-body text-sm text-white/50 hover:text-white transition-colors">Pirkanmaa</a>
              <a href="/keski-suomi" class="font-body text-sm text-white/50 hover:text-white transition-colors">Keski-Suomi</a>
              <a href="/energiaselvitys" class="font-body text-sm text-white/50 hover:text-white transition-colors">Energiaselvitys</a>
              <a href="/energiaselvitys-hinta" class="font-body text-sm text-white/50 hover:text-white transition-colors">Energiaselvityksen hinta</a>
              <a href="/energiatodistus-hinta" class="font-body text-sm text-white/50 hover:text-white transition-colors">Energiatodistuksen hinta</a>
              <a href="/lvi-suunnittelu-hinta" class="font-body text-sm text-white/50 hover:text-white transition-colors">LVI-suunnittelun hinta</a>
              <a href="/patteriverkoston-tasapainotus" class="font-body text-sm text-white/50 hover:text-white transition-colors">Patteriverkoston tasapainotus</a>
            </div>
          </div>

          <!-- Linkit -->
          <div class="flex items-center gap-4">
            <a
              href="https://www.linkedin.com/in/oskari-vattu-517936280/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-body text-[11px] tracking-[0.14em] uppercase text-white/40 hover:text-white transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a href="#yhteydenotto" class="font-body text-[11px] tracking-[0.14em] uppercase border border-white/25 px-5 py-2 text-white/60 hover:text-white hover:border-white/50 transition-colors">
              Ota yhteyttä
            </a>
          </div>

        </div>
      </div>
    </footer>
  </body>
</html>
