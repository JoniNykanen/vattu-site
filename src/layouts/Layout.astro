---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'LVI-insinööritoimisto Vattu Oy',
  description = 'LVI-suunnittelua asuin- ja toimitilakohteisiin sekä energiatodistukset ja -selvitykset. Uusimaa, Pirkanmaa, Keski-Suomi.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fi_FI" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://vattu-site.vercel.app/#business",
          "name": "LVI-insinööritoimisto Vattu Oy",
          "url": "https://vattu-site.vercel.app",
          "email": "oskari@vattu.fi",
          "telephone": "+358407656096",
          "vatID": "FI35626898",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Leineläntie 15 H 39",
            "postalCode": "01340",
            "addressLocality": "Vantaa",
            "addressCountry": "FI"
          },
          "areaServed": [
            { "@type": "State", "name": "Uusimaa" },
            { "@type": "State", "name": "Pirkanmaa" },
            { "@type": "State", "name": "Keski-Suomi" }
          ],
          "serviceType": [
            "LVI-suunnittelu",
            "Energiatodistus",
            "Energiaselvitys",
            "Patteriverkoston tasapainotus",
            "Olosuhde- ja energiasimulointi"
          ],
          "employee": {
            "@type": "Person",
            "name": "Oskari Vattu",
            "jobTitle": "LVI-suunnittelija",
            "sameAs": "https://www.linkedin.com/in/oskari-vattu-517936280/"
          },
          "sameAs": [
            "https://www.linkedin.com/in/oskari-vattu-517936280/",
            "https://www.finder.fi/LVI-suunnittelu/LVI-insin%C3%B6%C3%B6ritoimisto+Vattu+Oy/Vantaa/yhteystiedot/4233293"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://vattu-site.vercel.app/#website",
          "url": "https://vattu-site.vercel.app",
          "name": "LVI-insinööritoimisto Vattu Oy",
          "inLanguage": "fi",
          "publisher": { "@id": "https://vattu-site.vercel.app/#business" }
        }
      ]
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Anuphan:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-body text-base bg-cream text-[#1A1A1A]">
    <!-- Grain overlay — fixed, pointerevents-none -->
    <div class="fixed inset-0 z-[60] pointer-events-none opacity-[0.032]" style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.75%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22200%22 height=%22200%22 filter=%22url(%23n)%22 opacity=%221%22/></svg>');background-size:200px 200px;"></div>
    <slot />
    <footer class="bg-forest text-white pt-10 pb-24 lg:py-12">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">

          <!-- Yritystiedot -->
          <div>
            <p class="font-heading text-base mb-4">LVI-insinööritoimisto Vattu Oy</p>
            <div class="font-body text-sm text-white/60 space-y-1">
              <p><a href="mailto:oskari@vattu.fi" class="hover:text-white transition-colors">oskari@vattu.fi</a></p>
              <p><a href="tel:+358407656096" class="hover:text-white transition-colors">040 7656 096</a></p>
              <p class="flex items-center gap-2">
                Y-tunnus 3562689-8
                <a
                  href="https://www.finder.fi/LVI-suunnittelu/LVI-insin%C3%B6%C3%B6ritoimisto+Vattu+Oy/Vantaa/yhteystiedot/4233293"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-body text-[10px] tracking-[0.12em] uppercase text-white/30 hover:text-white/70 border border-white/15 px-2 py-0.5 transition-colors"
                >
                  Finder
                </a>
              </p>
            </div>
          </div>

          <!-- Sivut -->
          <div>
            <p class="font-body text-[10px] tracking-[0.2em] uppercase text-white/25 mb-3">Sivut</p>
            <div class="flex flex-col gap-1.5">
              <a href="/" class="font-body text-sm text-white/50 hover:text-white transition-colors">Etusivu</a>
              <a href="/uusimaa" class="font-body text-sm text-white/50 hover:text-white transition-colors">Uusimaa</a>
              <a href="/pirkanmaa" class="font-body text-sm text-white/50 hover:text-white transition-colors">Pirkanmaa</a>
              <a href="/keski-suomi" class="font-body text-sm text-white/50 hover:text-white transition-colors">Keski-Suomi</a>
            </div>
          </div>

          <!-- Linkit -->
          <div class="flex items-center gap-4">
            <a
              href="https://www.linkedin.com/in/oskari-vattu-517936280/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-body text-[11px] tracking-[0.14em] uppercase text-white/40 hover:text-white transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a href="#yhteydenotto" class="font-body text-[11px] tracking-[0.14em] uppercase border border-white/25 px-5 py-2 text-white/60 hover:text-white hover:border-white/50 transition-colors">
              Ota yhteyttä
            </a>
          </div>

        </div>
      </div>
    </footer>
  </body>
</html>
