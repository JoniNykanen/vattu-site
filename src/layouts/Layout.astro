---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'LVI-insinööritoimisto Vattu Oy',
  description = 'LVI-suunnittelua asuin- ja toimitilakohteisiin sekä energiatodistukset ja -selvitykset. Uusimaa, Pirkanmaa, Keski-Suomi.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Anuphan:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-body text-base bg-cream text-[#1A1A1A]">
    <slot />
  </body>
</html>
