---
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<header id="site-nav" class="hidden lg:flex fixed top-5 left-0 right-0 z-50 justify-center px-4 pointer-events-none">
  <nav class="pointer-events-auto flex items-center gap-6 bg-[#1C2B1C] rounded-full px-5 py-2.5 ring-1 ring-white/10 shadow-[0_4px_20px_rgba(0,0,0,0.12)] transition-[background-color,box-shadow] duration-500">

    <a href="/" class="font-heading text-white text-[13px] leading-tight mr-2 opacity-90 hover:opacity-100 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-forest rounded-sm">
      Vattu
    </a>

    <div class="w-px h-4 bg-white/15"></div>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-5">
      <a href="/" class={`font-body text-[11px] tracking-[0.12em] uppercase transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-forest rounded-sm ${currentPath === '/' ? 'text-accent' : 'text-white/45 hover:text-white'}`}>
        Etusivu
      </a>

      <!-- Palvelut dropdown -->
      <div class="relative group">
        <button
          id="nav-palvelut-btn"
          aria-expanded="false"
          aria-haspopup="true"
          class="flex items-center gap-1 font-body text-[11px] tracking-[0.12em] uppercase text-white/45 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-forest rounded-sm"
        >
          Palvelut
          <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <!-- Dropdown panel -->
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 w-60 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-[opacity,visibility] duration-200 pointer-events-none group-hover:pointer-events-auto">
          <div class="bg-forest/97 backdrop-blur-xl rounded-2xl ring-1 ring-white/10 shadow-[0_12px_40px_rgba(28,43,28,0.5)] p-4">
            <a href="/#palvelut" class="flex items-center justify-between font-body text-[12px] px-2 py-1.5 mb-3 pb-3 border-b border-white/8 text-white/70 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white/40 rounded-lg">
              Kaikki palvelut
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
            </a>
            <p class="font-body text-[9px] tracking-[0.2em] uppercase text-white/25 px-2 mb-2">Energia</p>
            <div class="space-y-0.5 mb-4">
              <a href="/energiaselvitys" class={`block font-body text-[12px] px-2 py-1.5 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white/40 ${currentPath === '/energiaselvitys' ? 'text-accent' : 'text-white/55 hover:text-white hover:bg-white/5'}`}>Energiaselvitys</a>
              <a href="/energiaselvitys-hinta" class={`block font-body text-[12px] px-2 py-1.5 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white/40 ${currentPath === '/energiaselvitys-hinta' ? 'text-accent' : 'text-white/55 hover:text-white hover:bg-white/5'}`}>Energiaselvityksen hinta</a>
              <a href="/energiatodistus-hinta" class={`block font-body text-[12px] px-2 py-1.5 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white/40 ${currentPath === '/energiatodistus-hinta' ? 'text-accent' : 'text-white/55 hover:text-white hover:bg-white/5'}`}>Energiatodistuksen hinta</a>
            </div>
            <div class="border-t border-white/8 pt-3">
              <p class="font-body text-[9px] tracking-[0.2em] uppercase text-white/25 px-2 mb-2">Suunnittelu</p>
              <div class="space-y-0.5">
                <a href="/lvi-suunnittelu-hinta" class={`block font-body text-[12px] px-2 py-1.5 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white/40 ${currentPath === '/lvi-suunnittelu-hinta' ? 'text-accent' : 'text-white/55 hover:text-white hover:bg-white/5'}`}>LVI-suunnittelun hinta</a>
                <a href="/patteriverkoston-tasapainotus" class={`block font-body text-[12px] px-2 py-1.5 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-white/40 ${currentPath === '/patteriverkoston-tasapainotus' ? 'text-accent' : 'text-white/55 hover:text-white hover:bg-white/5'}`}>Patteriverkoston tasapainotus</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="w-px h-4 bg-white/15 hidden lg:block"></div>

    <a
      href={currentPath === '/' ? '#yhteydenotto' : '/#yhteydenotto'}
      class="flex items-center gap-2 font-body text-[11px] tracking-[0.14em] uppercase text-white bg-white/10 hover:bg-white/20 rounded-full px-4 py-1.5 transition-[background-color] duration-300 active:scale-[0.97] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-forest"
    >
      Ota yhteyttä
      <span class="w-5 h-5 rounded-full bg-white/15 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
        </svg>
      </span>
    </a>

  </nav>
</header>
