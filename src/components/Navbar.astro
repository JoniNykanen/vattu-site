---
const currentPath = Astro.url.pathname;
---

<header id="site-nav" class="fixed top-5 left-0 right-0 z-50 flex justify-center px-4 pointer-events-none">
  <nav class="pointer-events-auto flex items-center gap-6 bg-forest/90 backdrop-blur-xl rounded-full px-5 py-2.5 ring-1 ring-white/10 shadow-[0_8px_32px_rgba(28,43,28,0.35)] transition-all duration-500">

    <a href="/" class="font-heading text-white text-[13px] leading-tight mr-2 opacity-90 hover:opacity-100 transition-opacity">
      Vattu
    </a>

    <div class="w-px h-4 bg-white/15"></div>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-5">
      <a href="/" class={`font-body text-[11px] tracking-[0.12em] uppercase transition-colors ${currentPath === '/' ? 'text-white' : 'text-white/45 hover:text-white'}`}>
        Etusivu
      </a>
      <a href="/uusimaa" class={`font-body text-[11px] tracking-[0.12em] uppercase transition-colors ${currentPath === '/uusimaa' ? 'text-white' : 'text-white/45 hover:text-white'}`}>
        Uusimaa
      </a>
      <a href="/pirkanmaa" class={`font-body text-[11px] tracking-[0.12em] uppercase transition-colors ${currentPath === '/pirkanmaa' ? 'text-white' : 'text-white/45 hover:text-white'}`}>
        Pirkanmaa
      </a>
      <a href="/keski-suomi" class={`font-body text-[11px] tracking-[0.12em] uppercase transition-colors ${currentPath === '/keski-suomi' ? 'text-white' : 'text-white/45 hover:text-white'}`}>
        Keski-Suomi
      </a>
    </div>

    <div class="w-px h-4 bg-white/15 hidden lg:block"></div>

    <a
      href={currentPath === '/' ? '#yhteydenotto' : '/'}
      class="flex items-center gap-2 font-body text-[11px] tracking-[0.14em] uppercase text-white bg-white/10 hover:bg-white/20 rounded-full px-4 py-1.5 transition-all duration-300 active:scale-[0.97]"
    >
      Ota yhteyttä
      <span class="w-5 h-5 rounded-full bg-white/15 flex items-center justify-center group-hover:translate-x-0.5 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
        </svg>
      </span>
    </a>

  </nav>
</header>
