---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import img0217 from '../assets/images/IMG_0217.jpg';
import img0223 from '../assets/images/IMG_0223.jpg';
---

<Layout
  title="LVI-suunnittelu Helsinki, Tampere, Jyväskylä | Vattu Oy"
  description="LVI-suunnittelija Uudellamaalla, Pirkanmaalla ja Keski-Suomessa. KVV, IV ja FISE-pätevyydet. Energiatodistukset ja -selvitykset. Pyydä ilmainen tarjous."
>

  <!-- ── HERO ── -->
  <section id="top" class="bg-forest relative">

    <!-- Mobiili + desktop: teksti + desktop-kuva -->
    <div class="w-full grid grid-cols-1 lg:grid-cols-2 lg:min-h-[100dvh]">

      <!-- Teksti -->
      <div class="relative flex flex-col justify-center px-8 lg:px-14 xl:px-20 pt-28 pb-8 lg:py-0">

        <!-- Eyebrow badge -->
        <div class="hero-label inline-flex items-center gap-2 mb-8 w-max">
          <span class="rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-white/10 text-white/60 ring-1 ring-white/10">
            LVI-insinööritoimisto Vattu Oy
          </span>
        </div>

        <h1 class="hero-title font-heading text-white leading-[1.05] mb-4" style="font-size: clamp(2rem, 5.5vw, 5rem);">
          LVI-suunnittelu<br />
          <em class="not-italic text-white/40">&</em> energia&shy;selvitykset
        </h1>

        <!-- Typewriter -->
        <p class="hero-title font-body text-[13px] tracking-[0.18em] uppercase text-white/55 mb-10 h-5">
          <span id="typewriter"></span><span class="typewriter-cursor">|</span>
        </p>

        <div class="hero-cta flex flex-col sm:flex-row gap-3">
          <a href="#yhteydenotto" class="group inline-flex items-center justify-center gap-3 font-body text-[11px] tracking-[0.16em] uppercase bg-accent text-white rounded-full px-6 py-3.5 hover:bg-accent/90 transition-colors duration-300 active:scale-[0.97] shadow-[0_2px_20px_rgba(196,136,58,0.30)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-forest">
            Varaa etäpalaveri
            <span class="w-6 h-6 rounded-full bg-forest/10 flex items-center justify-center group-hover:translate-x-0.5 group-hover:-translate-y-px transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
            </span>
          </a>
          <a href="#palvelut" class="inline-flex items-center justify-center font-body text-[11px] tracking-[0.16em] uppercase text-white/45 rounded-full px-6 py-3.5 ring-1 ring-white/15 hover:text-white hover:ring-white/30 transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-forest">
            Katso palvelut
          </a>
        </div>
      </div>

      <!-- Desktop-kuva placeholder -->
      <div class="hidden lg:block" aria-hidden="true"></div>

    </div>

    <!-- Desktop-kuva (section-relative, ei leikkaudu grid-itemistä) -->
    <div class="hidden lg:block absolute inset-y-0 right-0 w-1/2 overflow-hidden group">
      <Image
        src={img0217}
        alt="Oskari Vattu LVI-insinööri"
        fetchpriority="high"
        loading="eager"
        class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-[1.03]"
      />
      <!-- Perusoverlay -->
      <div class="absolute inset-0 bg-forest/15 transition-opacity duration-500 group-hover:opacity-0"></div>
      <!-- Alareuna-fade (aina näkyvissä, ei poistu hover:ssa) -->
      <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-forest to-transparent"></div>
      <!-- Hover-overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-forest/95 via-forest/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-10">
        <p class="font-body text-[10px] tracking-[0.22em] uppercase text-white/40 mb-3 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-75">LVI-suunnittelija</p>
        <h3 class="font-heading text-white text-2xl mb-4 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-100">Oskari Vattu</h3>
        <div class="mb-4"></div>
        <p class="font-body text-sm text-white/65 leading-relaxed max-w-[320px] translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-[175ms]">
          Yli 5 vuoden kokemus LVI-suunnittelusta. Aiemmin Heatco Finland Oy ja AirExet Oy. LUT-yliopiston energiatekniikan DI-opiskelija. AutoCAD & MagiCAD.
        </p>
        <div class="mt-5 flex gap-4 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-200">
          <a href="https://www.linkedin.com/in/oskari-vattu-517936280/" target="_blank" rel="noopener noreferrer" class="font-body text-[10px] tracking-[0.14em] uppercase text-white/40 hover:text-white border border-white/15 px-3 py-1.5 transition-colors duration-200">
            LinkedIn
          </a>
          <a href="mailto:oskari@vattu.fi" class="font-body text-[10px] tracking-[0.14em] uppercase text-white/40 hover:text-white border border-white/15 px-3 py-1.5 transition-colors duration-200">
            oskari@vattu.fi
          </a>
        </div>
      </div>
    </div>

    <!-- Mobiili: kuva tekstin alla -->
    <div class="lg:hidden px-3 pb-8">
      <div class="relative w-full aspect-[3/2] rounded-2xl overflow-hidden ring-1 ring-white/10 shadow-[0_8px_40px_rgba(0,0,0,0.35)]">
        <Image
          src={img0217}
          alt="Oskari Vattu LVI-insinööri"
          fetchpriority="high"
          loading="eager"
          class="w-full h-full object-cover object-[center_40%]"
        />
        <div class="absolute inset-0 bg-forest/20"></div>
      </div>
    </div>

  </section>

  <!-- Wave -->
  <div class="bg-forest overflow-hidden leading-none -mt-px -mb-px">
    <svg viewBox="0 0 1440 72" preserveAspectRatio="none" class="w-full block h-10 lg:h-14" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,36 C240,72 480,0 720,36 C960,72 1200,0 1440,36 L1440,72 L0,72 Z" fill="#F4F0E8" />
    </svg>
  </div>

  <!-- ── ESITTELY ── -->
  <section class="bg-cream py-10 lg:py-20">
    <div class="max-w-[640px] mx-auto px-6 lg:px-12">
      <span class="reveal inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-7">Esittely</span>
      <p class="reveal font-body text-base lg:text-lg text-[#1A1A1A] leading-relaxed mb-5 pl-4 border-l-2 border-forest/40">
        Tarjoan LVI-suunnittelua asuin- ja toimitilakohteisiin sekä moduulirakentamisen projekteihin.
      </p>
      <p class="reveal font-body text-sm text-[#1A1A1A]/65 leading-relaxed mb-4">
        Suunnittelussa keskityn toimiviin ja energiatehokkaisiin ratkaisuihin, jotka parantavat viihtyvyyttä ja pitävät kustannukset hallinnassa. Lisäksi toteutan energiatodistuksia, energiaselvityksiä sekä olosuhde- ja energiasimulointeja, joiden avulla varmistetaan hyvät sisäolosuhteet ja optimoidaan energiankulutus jo suunnitteluvaiheessa.
      </p>
      <p class="reveal font-body text-sm text-[#1A1A1A]/65 leading-relaxed">
        Toimin aktiivisesti Uudenmaan, Pirkanmaan ja Keski-Suomen alueella. Teen yhteistyötä luotettavien LVI-urakoitsijoiden kanssa — voit halutessasi pyytää kauttani tarjouksen myös toteutuksesta.
      </p>
    </div>
  </section>

  <!-- ── TILASTOT ── -->
  <section class="bg-forest py-8 lg:py-10">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-3 gap-4 lg:gap-8">
        <div class="stat-item text-center lg:px-10">
          <p class="font-heading text-white leading-none mb-1" style="font-size: clamp(2rem, 4vw, 3rem);">
            <span class="stat-number" data-target="5">0</span><span class="font-body text-white/40">+</span>
          </p>
          <p class="font-body text-[10px] tracking-[0.18em] uppercase text-white/35">Vuotta kokemusta</p>
        </div>
        <div class="stat-item text-center lg:px-10">
          <p class="font-heading text-white leading-none mb-1" style="font-size: clamp(2rem, 4vw, 3rem);">
            <span class="stat-number" data-target="3">0</span>
          </p>
          <p class="font-body text-[10px] tracking-[0.18em] uppercase text-white/35">Toimialuetta</p>
        </div>
        <div class="stat-item text-center lg:px-10">
          <p class="font-heading text-white leading-none mb-1" style="font-size: clamp(2rem, 4vw, 3rem);">
            <span class="stat-number" data-target="3">0</span>
          </p>
          <p class="font-body text-[10px] tracking-[0.18em] uppercase text-white/35">Pätevyyttä</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PÄTEVYYDET ── -->
  <section class="bg-cream py-10 lg:py-16">
    <div class="max-w-[760px] mx-auto px-6 lg:px-12">
      <span class="reveal inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-8">Pätevyydet</span>
      <div class="reveal-group divide-y divide-[#1A1A1A]/8">
        <div class="reveal flex items-start gap-8 lg:gap-12 py-6 first:pt-0">
          <span class="font-body text-[10px] tracking-[0.22em] uppercase text-forest/35 w-10 shrink-0 pt-1">KVV</span>
          <div>
            <p class="font-heading text-[#1A1A1A] text-sm mb-1.5">Kiinteistön vesi- ja viemärilaitteiston suunnittelija</p>
            <p class="font-body text-sm text-[#1A1A1A]/55 leading-relaxed">Tavanomainen taso. Kattaa pientalot, rivitalot ja taloyhtiöt. Pätevyys myönnetty FISE Oy:n toimesta.</p>
          </div>
        </div>
        <div class="reveal flex items-start gap-8 lg:gap-12 py-6">
          <span class="font-body text-[10px] tracking-[0.22em] uppercase text-forest/35 w-10 shrink-0 pt-1">IV</span>
          <div>
            <p class="font-heading text-[#1A1A1A] text-sm mb-1.5">Ilmanvaihdon suunnittelija</p>
            <p class="font-body text-sm text-[#1A1A1A]/55 leading-relaxed">Tavanomainen taso. Ilmanvaihtojärjestelmien suunnittelu uudis- ja saneerauskohteisiin. Pätevyys myönnetty FISE Oy:n toimesta.</p>
          </div>
        </div>
        <div class="reveal flex items-start gap-8 lg:gap-12 py-6">
          <span class="font-body text-[10px] tracking-[0.22em] uppercase text-forest/35 w-10 shrink-0 pt-1">FISE</span>
          <div>
            <p class="font-heading text-[#1A1A1A] text-sm mb-1.5">Energiatodistuksen laatija, ylempi taso</p>
            <p class="font-body text-sm text-[#1A1A1A]/55 leading-relaxed">Korkein saatavilla oleva pätevyysluokka. Kattaa asuinrakennukset ja vaativat toimitilakohteet. Todistukset rekisteröidään Varken energiatodistusrekisteriin.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PALVELUT ── -->
  <section id="palvelut" class="bg-cream py-10 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
      <span class="reveal inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-3">Palvelut</span>
      <h2 class="reveal font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-10">Mitä teen</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-24">
        <div class="reveal">
          <div class="accordion divide-y divide-[#1A1A1A]/20">
            <div class="accordion-item" data-open="true">
              <button class="accordion-trigger w-full flex items-center justify-between py-4 text-left font-body text-[#1A1A1A] hover:text-forest transition-colors" aria-expanded="true" aria-controls="panel-asuinrakennukset">
                <span class="text-base">Asuinrakennukset & toimitilat</span>
                <span class="accordion-icon text-xl leading-none select-none" aria-hidden="true">−</span>
              </button>
              <div id="panel-asuinrakennukset" class="accordion-panel overflow-hidden transition-all duration-300">
                <p class="font-body text-sm text-[#1A1A1A]/80 leading-relaxed pb-3">
                  LVI-suunnittelua uusiin ja saneerattaviin asuin- ja toimitilakohteisiin. Suunnittelussa huomioidaan toimivuus, viihtyvyys ja energiatehokkuus kohteen tarpeiden mukaan. Tekniikasta on saatavissa myös BIM-tietomallit 3D-suunnitteluun. Palvelen muun muassa rakennuttajia, isännöitsijöitä ja yksityishenkilöitä. Toteutan suunnittelua myös alihankintana.
                </p>
                <a href="/lvi-suunnittelu-hinta" class="inline-block font-body text-[10px] tracking-[0.16em] uppercase text-accent hover:text-accent/70 transition-colors pb-5">Katso hinnat</a>
              </div>
            </div>
            <div class="accordion-item" data-open="false">
              <button class="accordion-trigger w-full flex items-center justify-between py-4 text-left font-body text-[#1A1A1A] hover:text-forest transition-colors" aria-expanded="false" aria-controls="panel-moduuli">
                <span class="text-base">Moduulirakentaminen</span>
                <span class="accordion-icon text-xl leading-none select-none" aria-hidden="true">+</span>
              </button>
              <div id="panel-moduuli" class="accordion-panel overflow-hidden transition-all duration-300" style="max-height: 0;">
                <p class="font-body text-sm text-[#1A1A1A]/80 leading-relaxed pb-5">
                  LVI-suunnittelua moduulirakentamisen projekteihin, jossa vaaditaan tarkkuutta ja tiivistä yhteistyötä muiden suunnittelijoiden kanssa.
                </p>
              </div>
            </div>
            <div class="accordion-item" data-open="false">
              <button class="accordion-trigger w-full flex items-center justify-between py-4 text-left font-body text-[#1A1A1A] hover:text-forest transition-colors" aria-expanded="false" aria-controls="panel-patteri">
                <span class="text-base">Patteriverkoston tasapainotus</span>
                <span class="sr-only"> (lämmitysverkoston tasapainotus)</span>
                <span class="accordion-icon text-xl leading-none select-none" aria-hidden="true">+</span>
              </button>
              <div id="panel-patteri" class="accordion-panel overflow-hidden transition-all duration-300" style="max-height: 0;">
                <p class="font-body text-sm text-[#1A1A1A]/80 leading-relaxed pb-3">
                  Patteriverkoston eli lämmitysverkoston tasapainotuksella varmistetaan lämmön tasainen jakautuminen kiinteistössä. Tulos: energiatehokkuus paranee, kylmät huoneet lämpenevät ja lämmityskustannukset laskevat.
                </p>
                <a href="/patteriverkoston-tasapainotus" class="inline-block font-body text-[10px] tracking-[0.16em] uppercase text-accent hover:text-accent/70 transition-colors pb-5">Lue lisää</a>
              </div>
            </div>
            <div class="accordion-item" data-open="false">
              <button class="accordion-trigger w-full flex items-center justify-between py-4 text-left font-body text-[#1A1A1A] hover:text-forest transition-colors" aria-expanded="false" aria-controls="panel-energia">
                <span class="text-base">Energiatodistukset & Energiaselvitykset</span>
                <span class="accordion-icon text-xl leading-none select-none" aria-hidden="true">+</span>
              </button>
              <div id="panel-energia" class="accordion-panel overflow-hidden transition-all duration-300" style="max-height: 0;">
                <p class="font-body text-sm text-[#1A1A1A]/80 leading-relaxed pb-3">
                  Laadin energiatodistukset ja -selvitykset asuinrakennuksille ja toimitiloille. Minulla on ylempi FISE-pätevyys — korkein saatavilla oleva taso.
                </p>
                <div class="flex gap-4 pb-5">
                  <a href="/energiaselvitys" class="font-body text-[10px] tracking-[0.16em] uppercase text-accent hover:text-accent/70 transition-colors">Energiaselvitys</a>
                  <a href="/energiatodistus-hinta" class="font-body text-[10px] tracking-[0.16em] uppercase text-accent hover:text-accent/70 transition-colors">Energiatodistus</a>
                </div>
              </div>
            </div>
            <div class="accordion-item" data-open="false">
              <button class="accordion-trigger w-full flex items-center justify-between py-4 text-left font-body text-[#1A1A1A] hover:text-forest transition-colors" aria-expanded="false" aria-controls="panel-simulointi">
                <span class="text-base">Olosuhde- ja energiasimulointi</span>
                <span class="accordion-icon text-xl leading-none select-none" aria-hidden="true">+</span>
              </button>
              <div id="panel-simulointi" class="accordion-panel overflow-hidden transition-all duration-300" style="max-height: 0;">
                <p class="font-body text-sm text-[#1A1A1A]/80 leading-relaxed pb-5">
                  Olosuhde- ja energiasimuloinnilla varmistetaan hyvät sisäolosuhteet ja optimoidaan energiankulutus jo suunnitteluvaiheessa ennen rakentamista.
                </p>
              </div>
            </div>
          </div>
          <div class="mt-10">
            <a href="#yhteydenotto" class="inline-block font-body text-[11px] tracking-[0.18em] uppercase bg-forest text-white px-8 py-4 hover:bg-forest/80 transition-colors active:scale-[0.98]">
              Ota yhteyttä
            </a>
          </div>
        </div>
        <div class="hidden lg:block reveal">
          <div class="sticky top-24">
            <Image
              src={img0223}
              alt="Suomalainen metsämaisema"
              loading="lazy"
              class="w-full aspect-[3/4] object-cover object-center"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MITEN TOIMITAAN ── -->
  <section id="prosessi" class="bg-forest py-10 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-20 items-start">

        <!-- Vasen: otsikko -->
        <div>
          <p class="font-body text-[10px] tracking-[0.22em] uppercase text-white/25 mb-3">Prosessi</p>
          <h2 class="font-heading text-white leading-[1.1] mb-4" style="font-size: clamp(1.5rem, 2.5vw, 2.25rem);">
            Miten yhteistyö<br />toimii
          </h2>
          <p class="font-body text-sm text-white/45 leading-relaxed max-w-[280px]">
            Kolme vaihetta tarjouksesta käynnistyvään projektiin.
          </p>
        </div>

        <!-- Oikea: askeleet pystysuoraan -->
        <div class="space-y-0">
          <div class="reveal grid grid-cols-[2.5rem_1fr] gap-5 py-7">
            <p class="font-heading text-white/15 text-3xl leading-none">01</p>
            <div>
              <h3 class="font-heading text-white text-base mb-2">Ota yhteyttä</h3>
              <p class="font-body text-sm text-white/50 leading-relaxed">
                Lähetä viesti tai varaa ilmainen etäpalaveri kalenterista. Ei sitoumuksia.
              </p>
            </div>
          </div>
          <div class="reveal grid grid-cols-[2.5rem_1fr] gap-5 py-7">
            <p class="font-heading text-white/15 text-3xl leading-none">02</p>
            <div>
              <h3 class="font-heading text-white text-base mb-2">Käydään projekti läpi</h3>
              <p class="font-body text-sm text-white/50 leading-relaxed">
                Sovitaan etäpalaverissa laajuus, aikataulu ja hinta. Saat selkeän tarjouksen.
              </p>
            </div>
          </div>
          <div class="reveal grid grid-cols-[2.5rem_1fr] gap-5 py-7">
            <p class="font-heading text-white/15 text-3xl leading-none">03</p>
            <div>
              <h3 class="font-heading text-white text-base mb-2">Aloitetaan</h3>
              <p class="font-body text-sm text-white/50 leading-relaxed">
                Suunnittelu käynnistyy sovitussa aikataulussa. Pidän sinut ajan tasalla.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Wave -->
  <div class="bg-forest overflow-hidden leading-none -mb-px">
    <svg viewBox="0 0 1440 72" preserveAspectRatio="none" class="w-full block h-10 lg:h-14" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,36 C240,0 480,72 720,36 C960,0 1200,72 1440,36 L1440,72 L0,72 Z" fill="#F4F0E8" />
    </svg>
  </div>

  <!-- ── YHTEYDENOTTO ── -->
  <section id="yhteydenotto" class="bg-cream pt-10 pb-24 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
      <span class="reveal inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-3">Yhteydenotto</span>
      <h2 class="reveal font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-3">Aloitetaan yhdessä</h2>
      <p class="reveal font-body text-sm text-[#1A1A1A]/50 mb-10 max-w-[480px]">
        Varaa ilmainen etäpalaveri tai lähetä viesti. Vastaan arkisin 1–2 päivän sisällä.
      </p>

      <!-- Kalenteri — desktop: iframe, mobiili: nappi -->
      <div class="reveal mb-10">

        <!-- Desktop iframe -->
        <div class="hidden lg:block border border-[#1A1A1A]/8 overflow-hidden shadow-sm">
          <div class="bg-forest/5 border-b border-[#1A1A1A]/8 px-5 py-3 flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-forest/40"></div>
            <span class="font-body text-[11px] tracking-[0.14em] uppercase text-[#1A1A1A]/35">LVI-insinööritoimisto Vattu Oy — Ilmainen etäpalaveri 60 min</span>
          </div>
          <iframe
            src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0EiCYaQeHPOreKXBXVhRlFcn7Ag2rVd6PC4938WN1oFasif4wKNPu8jUwBSsfZKMKPWs0oqAld?gv=true"
            style="border: 0; display: block;"
            width="100%"
            height="600"
            frameborder="0"
