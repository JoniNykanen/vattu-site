<style>
  .hero-label  { animation: fadeUp .8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: .1s;  opacity: 0; }
  .hero-title  { animation: fadeUp .8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: .25s; opacity: 0; }
  .hero-cta    { animation: fadeUp .8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: .45s; opacity: 0; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(22px);
    filter: blur(4px);
    transition: opacity .8s cubic-bezier(0.16, 1, 0.3, 1),
                transform .8s cubic-bezier(0.16, 1, 0.3, 1),
                filter .8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0px);
  }

  /* Staggered siblings */
  .reveal-group .reveal:nth-child(1) { transition-delay: 0ms; }
  .reveal-group .reveal:nth-child(2) { transition-delay: 80ms; }
  .reveal-group .reveal:nth-child(3) { transition-delay: 160ms; }
  .reveal-group .reveal:nth-child(4) { transition-delay: 240ms; }

  /* Typewriter cursor */
  .typewriter-cursor {
    opacity: 1;
    animation: blink .75s step-end infinite;
    color: rgba(255,255,255,0.3);
  }
  @keyframes blink { 50% { opacity: 0; } }

  @media (prefers-reduced-motion: reduce) {
    .hero-label, .hero-title, .hero-cta { animation: none; opacity: 1; }
    .reveal { transition: none; opacity: 1; transform: none; filter: none; }
    .typewriter-cursor { animation: none; }
  }

  /* Button directional fill */
  .btn-primary {
    position: relative;
    overflow: hidden;
  }
  .btn-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    transform: translateX(-101%);
    transition: transform .35s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }
  .btn-primary:hover::after { transform: translateX(0); }
  .btn-primary span {
    position: relative;
    z-index: 1;
    transition: color .35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-primary:hover span { color: #1C2B1C; }
</style>

<script>
  function initPage() {
    // ── Hero animations reset (nav-palatessa animaatio ei muuten toistu) ──
    document.querySelectorAll<HTMLElement>('.hero-label, .hero-title, .hero-cta').forEach(el => {
      el.style.animation = 'none';
      void el.offsetWidth; // force reflow
      el.style.animation = '';
    });

    // ── Typewriter ──
    const typeEl = document.getElementById('typewriter');
    if (typeEl) {
      typeEl.textContent = '';
      const phrases = ['LVI-suunnittelu', 'Energiatodistukset', 'Energiasimulointi', 'Patteriverkoston tasapainotus', 'Moduulirakentaminen'];
      let pi = 0, ci = 0, deleting = false;
      let timer: ReturnType<typeof setTimeout>;
      const type = () => {
        const phrase = phrases[pi];
        typeEl.textContent = deleting ? phrase.slice(0, ci--) : phrase.slice(0, ci++);
        if (!deleting && ci > phrase.length) { deleting = true; timer = setTimeout(type, 1800); return; }
        if (deleting && ci < 0)             { deleting = false; pi = (pi + 1) % phrases.length; ci = 0; timer = setTimeout(type, 400); return; }
        timer = setTimeout(type, deleting ? 35 : 65);
      };
      timer = setTimeout(type, 1200);
    }

    // ── Count-up ──
    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target.querySelector('.stat-number') as HTMLElement;
        if (!el) return;
        const target = parseInt(el.dataset.target || '0');
        let current = 0;
        const step = () => {
          current++;
          el.textContent = String(current);
          if (current < target) setTimeout(step, 120);
        };
        step();
        statObserver.unobserve(entry.target);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.stat-item').forEach(el => statObserver.observe(el));

    // ── Accordion ──
    document.querySelectorAll('.accordion-item').forEach((item) => {
      const trigger = item.querySelector('.accordion-trigger') as HTMLButtonElement;
      const panel   = item.querySelector('.accordion-panel') as HTMLElement;
      const icon    = item.querySelector('.accordion-icon') as HTMLElement;

      if (item.getAttribute('data-open') === 'true') {
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }

      trigger.addEventListener('click', () => {
        const isOpen = item.getAttribute('data-open') === 'true';
        if (isOpen) {
          panel.style.maxHeight = '0';
          icon.textContent = '+';
          item.setAttribute('data-open', 'false');
          trigger.setAttribute('aria-expanded', 'false');
        } else {
          panel.style.maxHeight = panel.scrollHeight + 'px';
          icon.textContent = '−';
          item.setAttribute('data-open', 'true');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // ── Scroll reveal ──
    const reveals = document.querySelectorAll<HTMLElement>('.reveal');
    reveals.forEach(el => el.classList.remove('visible'));
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08 }
    );
    reveals.forEach((el) => revealObserver.observe(el));

    // ── Sticky nav shadow ──
    const nav = document.getElementById('site-nav');
    window.addEventListener('scroll', () => {
      window.scrollY > 10
        ? nav?.classList.add('shadow-sm', 'shadow-black/8')
        : nav?.classList.remove('shadow-sm', 'shadow-black/8');
    }, { passive: true });
  }

  // Käynnistyy sekä ensimmäisellä latauksella että jokaisella ClientRouter-navigoinnilla
  document.addEventListener('astro:page-load', initPage);
</script>
