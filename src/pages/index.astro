<style>
  .hero-label  { animation: fadeUp .8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: .1s;  opacity: 0; }
  .hero-title  { animation: fadeUp .8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: .25s; opacity: 0; }
  .hero-cta    { animation: fadeUp .8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: .45s; opacity: 0; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(22px);
    filter: blur(4px);
    transition: opacity .8s cubic-bezier(0.16, 1, 0.3, 1),
                transform .8s cubic-bezier(0.16, 1, 0.3, 1),
                filter .8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0px);
  }

  /* Staggered siblings */
  .reveal-group .reveal:nth-child(1) { transition-delay: 0ms; }
  .reveal-group .reveal:nth-child(2) { transition-delay: 80ms; }
  .reveal-group .reveal:nth-child(3) { transition-delay: 160ms; }
  .reveal-group .reveal:nth-child(4) { transition-delay: 240ms; }

  /* Typewriter cursor */
  .typewriter-cursor {
    opacity: 1;
    animation: blink .75s step-end infinite;
    color: rgba(255,255,255,0.3);
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* Button directional fill */
  .btn-primary {
    position: relative;
    overflow: hidden;
  }
  .btn-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    transform: translateX(-101%);
    transition: transform .35s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }
  .btn-primary:hover::after { transform: translateX(0); }
  .btn-primary span {
    position: relative;
    z-index: 1;
    transition: color .35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-primary:hover span { color: #1C2B1C; }
</style>

<script>
  // ── Hiukkasanimaatio (ilmavirtaus) ──
  const canvas = document.getElementById('flow-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0;
    const particles: { x: number; y: number; vx: number; vy: number; r: number; a: number }[] = [];

    const resize = () => {
      W = canvas.offsetWidth;
      H = canvas.offsetHeight;
      canvas.width = W;
      canvas.height = H;
    };
    resize();
    window.addEventListener('resize', resize, { passive: true });

    for (let i = 0; i < 55; i++) {
      particles.push({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.3) * 0.4,
        vy: (Math.random() - 0.7) * 0.3,
        r: Math.random() * 1.8 + 0.4,
        a: Math.random() * 0.6 + 0.2,
      });
    }

    const draw = () => {
      ctx.clearRect(0, 0, W, H);
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -4) p.x = W + 4;
        if (p.x > W + 4) p.x = -4;
        if (p.y < -4) p.y = H + 4;
        if (p.y > H + 4) p.y = -4;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${p.a})`;
        ctx.fill();
      }
      requestAnimationFrame(draw);
    };
    draw();
  }

  // ── Typewriter ──
  const typeEl = document.getElementById('typewriter');
  if (typeEl) {
    const phrases = ['LVI-suunnittelu', 'Energiatodistukset', 'Energiasimulointi', 'Patteriverkoston tasapainotus', 'Moduulirakentaminen'];
    let pi = 0, ci = 0, deleting = false;
    const type = () => {
      const phrase = phrases[pi];
      typeEl.textContent = deleting ? phrase.slice(0, ci--) : phrase.slice(0, ci++);
      if (!deleting && ci > phrase.length) { deleting = true; setTimeout(type, 1800); return; }
      if (deleting && ci < 0)             { deleting = false; pi = (pi + 1) % phrases.length; ci = 0; setTimeout(type, 400); return; }
      setTimeout(type, deleting ? 35 : 65);
    };
    setTimeout(type, 1200);
  }

  // ── Count-up ──
  const statObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target.querySelector('.stat-number') as HTMLElement;
      if (!el) return;
      const target = parseInt(el.dataset.target || '0');
      let current = 0;
      const step = () => {
        current++;
        el.textContent = String(current);
        if (current < target) setTimeout(step, 120);
      };
      step();
      statObserver.unobserve(entry.target);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.stat-item').forEach(el => statObserver.observe(el));

  // Accordion
  document.querySelectorAll('.accordion-item').forEach((item) => {
    const trigger = item.querySelector('.accordion-trigger') as HTMLButtonElement;
    const panel   = item.querySelector('.accordion-panel') as HTMLElement;
    const icon    = item.querySelector('.accordion-icon') as HTMLElement;

    if (item.getAttribute('data-open') === 'true') {
      panel.style.maxHeight = panel.scrollHeight + 'px';
    }

    trigger.addEventListener('click', () => {
      const isOpen = item.getAttribute('data-open') === 'true';
      if (isOpen) {
        panel.style.maxHeight = '0';
        icon.textContent = '+';
        item.setAttribute('data-open', 'false');
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        panel.style.maxHeight = panel.scrollHeight + 'px';
        icon.textContent = '−';
        item.setAttribute('data-open', 'true');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  reveals.forEach((el) => observer.observe(el));

  // Sticky nav shadow
  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    window.scrollY > 10
      ? nav?.classList.add('shadow-sm', 'shadow-black/8')
      : nav?.classList.remove('shadow-sm', 'shadow-black/8');
  }, { passive: true });

  // Bottom nav active state
  const sections = ['top', 'palvelut', 'prosessi', 'yhteydenotto'];
  const navBtns = document.querySelectorAll('.mobile-nav-btn');

  const setActive = (id: string) => {
    navBtns.forEach((btn) => {
      const href = btn.getAttribute('href');
      const isActive = href === `#${id}`;
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('text-white/40', !isActive);
    });
  };

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    },
    { threshold: 0.3 }
  );

  sections.forEach((id) => {
    const el = document.getElementById(id);
    if (el) sectionObserver.observe(el);
  });
</script>
