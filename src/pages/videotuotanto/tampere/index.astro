---
import Layout from '../../../layouts/Layout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Etusivu", "item": "https://ruskamedia.com/" },
    { "@type": "ListItem", "position": 2, "name": "Videotuotanto", "item": "https://ruskamedia.com/videotuotanto/" },
    { "@type": "ListItem", "position": 3, "name": "Videotuotanto Tampere", "item": "https://ruskamedia.com/videotuotanto/tampere/" }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Videotuotanto Tampere",
  "serviceType": "Videotuotanto",
  "provider": { "@type": "LocalBusiness", "name": "Ruska Media", "url": "https://ruskamedia.com" },
  "areaServed": { "@type": "City", "name": "Tampere" },
  "url": "https://ruskamedia.com/videotuotanto/tampere/"
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Mitä videotuotanto maksaa Tampereella?", "acceptedAnswer": { "@type": "Answer", "text": "Hinnat ovat samat kuin Jyväskylässäkin — yritysvideo alkaen 1 500 €, laajempi kampanja 3 000–8 000 €. Matkakulut Tampereelle lisätään tarjoukseen." }},
    { "@type": "Question", "name": "Kuvaatteko myös muualla Pirkanmaalla?", "acceptedAnswer": { "@type": "Answer", "text": "Kyllä. Koko Pirkanmaa onnistuu. Matkakulut lasketaan etäisyyden mukaan." }},
    { "@type": "Question", "name": "Sopiiko videotuotanto erikokoisille tamperelaisyrityksille?", "acceptedAnswer": { "@type": "Answer", "text": "Kyllä. Olemme kuvanneet Tampereella pienyrittäjistä kasvuyrityksiin. Yksinkertainen käyntikorttivideo ja laaja kampanja ovat eri asioita — kerro tarve, räätälöidään sopiva paketti." }}
  ]
};
---
<Layout
  title="Videotuotanto Tampere — Yritysvideot & brändivideot | Ruska Media"
  description="Videotuotanto Tampereella — yritysvideot, brändivideot ja rekrytointivideot. Matka Jyväskylästä ~1h 40min. Ruska Media palvelee koko Pirkanmaan."
  canonical="https://ruskamedia.com/videotuotanto/tampere/"
  schema={[breadcrumbSchema, serviceSchema, faqSchema]}
>

  <!-- HERO -->
  <section class="relative w-full overflow-hidden" style="height:500px; background-image:url('https://ruskamedia.com/wp-content/uploads/2025/08/Ruska-Media-Videotuotanto.jpg'); background-size:cover; background-position:center;">
    <div class="absolute inset-0 bg-black" style="opacity:0.6;"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6" style="z-index:1; margin-top:70px;">
      <p style="color:#aaa; font-size:13px; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:12px;">Ruska Media</p>
      <h1 class="font-heading text-white uppercase tracking-widest font-normal anim-fade-up" style="font-size:38px;">Videotuotanto Tampere</h1>
    </div>
  </section>

  <!-- INTRO -->
  <section style="background-color:#1e1e1e; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto; text-align:center;">
      <p style="color:#bbb; font-size:15px; line-height:1.9;">
        Tampere on yksi kaupungeista, joissa käymme useimmin — ja hyvästä syystä. Siellä on aktiivisia yrityksiä, ja etäisyys Jyväskylästä on sen verran lyhyt, että projekti onnistuu yhdessä päivässä ilman yöpymistä. Olemme kuvanneet Tampereella yrityksille videoita useita kertoja, joten kaupungin kuvauslokaatiot ja käytännöt ovat tuttuja. Matkakulut lasketaan tarjoukseen avoimesti.
      </p>
    </div>
  </section>

  <!-- PAIKALLINEN KONTEKSTI -->
  <section style="background-color:#111; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest" style="font-size:18px; text-align:center; margin-bottom:36px;">Videotuotanto Tampereella — miksi toimii</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
        {[
          ['Kasvava yritysmarkkina', 'Tampere houkuttelee kasvavia teknologiayrityksiä — videotuotannon tarve on suuri ja budjetit kunnossa.'],
          ['Finlayson ja teollisuusmiljöö', 'Tampereen historiallinen teollisuusympäristö tarjoaa ainutlaatuisia kuvauspaikkaoja yritysvideoihin.'],
          ['Nokia-areena ja tapahtumat', 'Isot tapahtumat ja konferenssit — Tampere on Suomen toiseksi tärkein tapahtumapaikkakunnat.'],
          ['1h 40min Jyväskylästä', 'Nopea matka — kuvauspäivä onnistuu sujuvasti ilman yöpymistarvetta lyhyemmissä projekteissa.'],
        ].map(([nimi, kuvaus]) => (
          <div style="border-left:2px solid #fd8c03; padding-left:18px;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:14px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{nimi}</h3>
            <p style="color:#888; font-size:13px; line-height:1.7;">{kuvaus}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PALVELUT -->
  <section style="background-color:#1a1a1a; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto; text-align:center;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:18px;">Mitä tuotamme Tampereella</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; text-align:left;">
        {[
          ['Yritysvideot ja brändivideot', 'Yrityksen tarina, arvot ja palvelut elokuvamaisen laadun kautta.'],
          ['Rekrytointivideot', 'Tampereella kilpailu osaajista on kovaa — rekrytointivideo erottaa työnantajan massasta.'],
          ['Tapahtumavideot', 'Konferenssit, seminaarit ja tuotelanseeraukset — koko tapahtuma tallennettuna.'],
          ['Some-videot', 'LinkedIn, Instagram, YouTube — lyhyet videot jotka toimivat Tampereen yritysmarkkinassa.'],
        ].map(([otsikko, teksti]) => (
          <a href="/varaa/videomarkkinointi" class="pricing-card" style="background:#222; border-radius:4px; padding:20px; gap:10px;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{otsikko}</h3>
            <p style="color:#888; font-size:13px; line-height:1.7;">{teksti}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background-color:#111; padding:60px 20px;" class="faq">
    <div style="max-width:700px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:18px; text-align:center;">Usein kysyttyä — Tampere</h2>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer;">Mitä videotuotanto maksaa Tampereella?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Hinnat ovat samat kuin Jyväskylässäkin — yritysvideo alkaen 1 500 €, laajempi kampanja 3 000–8 000 €. Matkakulut Tampereelle lisätään tarjoukseen.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer;">Kuvaatteko myös muualla Pirkanmaalla?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Kyllä. Koko Pirkanmaa onnistuu. Matkakulut lasketaan etäisyyden mukaan.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer;">Sopiiko videotuotanto erikokoisille tamperelaisyrityksille?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Kyllä. Olemme kuvanneet Tampereella pienyrittäjistä kasvuyrityksiin. Yksinkertainen käyntikorttivideo ja laaja kampanja ovat eri asioita — kerro tarve, räätälöidään sopiva paketti.</p>
      </details>
    </div>
  </section>

  <!-- CTA -->
  <section style="background-color:#1a1a1a; padding:60px 20px; text-align:center;">
    <div style="max-width:500px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-6" style="font-size:18px;">Pyydä tarjous — Tampere</h2>
      <a href="/varaa/videomarkkinointi/?kaupunki=Tampere" class="btn-white">Pyydä tarjous</a>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section style="background-color:#111; padding:30px 20px; text-align:center;">
    <div style="display:flex; flex-wrap:wrap; gap:16px; justify-content:center;">
      <a href="/videotuotanto/" class="btn-ghost">Videotuotanto koko Suomessa</a>
      <a href="/videotuotanto/jyvaskyla/" class="btn-ghost">Videotuotanto Jyväskylä</a>
      <a href="/videotuotanto/helsinki/" class="btn-ghost">Videotuotanto Helsinki</a>
    </div>
  </section>

</Layout>
