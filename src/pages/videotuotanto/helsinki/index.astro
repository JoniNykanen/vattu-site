---
import Layout from '../../../layouts/Layout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Etusivu", "item": "https://ruskamedia.com/" },
    { "@type": "ListItem", "position": 2, "name": "Videotuotanto", "item": "https://ruskamedia.com/videotuotanto/" },
    { "@type": "ListItem", "position": 3, "name": "Videotuotanto Helsinki", "item": "https://ruskamedia.com/videotuotanto/helsinki/" }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Videotuotanto Helsinki",
  "serviceType": "Videotuotanto",
  "provider": { "@type": "LocalBusiness", "name": "Ruska Media", "url": "https://ruskamedia.com" },
  "areaServed": { "@type": "City", "name": "Helsinki" },
  "url": "https://ruskamedia.com/videotuotanto/helsinki/"
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Mitä videotuotanto maksaa Helsingissä?", "acceptedAnswer": { "@type": "Answer", "text": "Hinnat ovat samat riippumatta kaupungista — yritysvideo alkaen 1 500 €, laajempi kampanja 3 000–8 000 €. Matkakulut Helsinkiin lisätään tarjoukseen. Pitkissä projekteissa sovitaan yöpymisestä tarvittaessa." }},
    { "@type": "Question", "name": "Teettekö myös englanninkielisiä tuotantoja?", "acceptedAnswer": { "@type": "Answer", "text": "Kyllä. Englanninkieliset tuotannot kansainvälisille markkinoille onnistuvat. Sovitaan projektikohtaisesti." }},
    { "@type": "Question", "name": "Toimiiko videotuotanto myös pääkaupunkiseudun ulkopuolisten yritysten markkinointiin?", "acceptedAnswer": { "@type": "Answer", "text": "Kyllä. Kohderyhmä ratkaisee enemmän kuin kuvauspaikka. Olemme tuottaneet videoita, jotka on kohdennettu Helsinkiin, Tampereelle tai koko Suomeen — sijainnilla ei ole merkitystä sille, kenelle video tehdään." }}
  ]
};
---
<Layout
  title="Videotuotanto Helsinki — Yritysvideot & brändivideot | Ruska Media"
  description="Videotuotanto Helsingissä — yritysvideot, brändivideot ja rekrytointivideot. Helsinki on Suomen suurin yritysmarkkina. Ruska Media palvelee koko pääkaupunkiseudun."
  canonical="https://ruskamedia.com/videotuotanto/helsinki/"
  schema={[breadcrumbSchema, serviceSchema, faqSchema]}
>

  <!-- HERO -->
  <section class="relative w-full overflow-hidden" style="height:500px; background-image:url('https://ruskamedia.com/wp-content/uploads/2025/08/Ruska-Media-Videotuotanto.jpg'); background-size:cover; background-position:center;">
    <div class="absolute inset-0 bg-black" style="opacity:0.6;"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6" style="z-index:1; margin-top:70px;">
      <p style="color:#aaa; font-size:13px; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:12px;">Ruska Media</p>
      <h1 class="font-heading text-white uppercase tracking-widest font-normal anim-fade-up" style="font-size:38px;">Videotuotanto Helsinki</h1>
    </div>
  </section>

  <!-- INTRO -->
  <section style="background-color:#1e1e1e; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto; text-align:center;">
      <p style="color:#bbb; font-size:15px; line-height:1.9;">
        Helsingissä käymme kuvaamassa harvemmin kuin Tampereella, mutta käymme. Matka on noin 3 tuntia, joten se vaatii aina etukäteissuunnittelun — lähtöaikaiset ja kuvauspaikat sovitaan tarkkaan ennen reissua. Helsinki kannattaa yhdistää tarvittaessa muihin pääkaupunkiseudun projekteihin. Laatu on sama kuin Jyväskylässä, hintaan lisätään vain matkakulut tai majoitus avoimesti.
      </p>
    </div>
  </section>

  <!-- PAIKALLINEN KONTEKSTI -->
  <section style="background-color:#111; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest" style="font-size:18px; text-align:center; margin-bottom:36px;">Videotuotanto Helsingissä — miksi toimii</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
        {[
          ['Suomen suurin yritysmarkkina', 'Helsinki on kansainvälisten ja kasvavien yritysten keskittymä — laadukas video on täällä kilpailuetu, ei lisämaine.'],
          ['Korkeimmat budjetit', 'Helsinkiläiset yritykset investoivat videotuotantoon enemmän kuin missään muualla Suomessa. Laatu näkyy.'],
          ['Merellinen ympäristö', 'Suomenlinna, satama, Kaivopuisto — Helsinki tarjoaa ainutlaatuisia kuvauspaikkaoja joita ei muualla ole.'],
          ['Tehokas kuvauspäivä', 'Suunnittelemme päivän niin, että matkaan ei mene kuvausaikaa. Useampi lokaatio samana päivänä.'],
        ].map(([nimi, kuvaus]) => (
          <div style="border-left:2px solid #fd8c03; padding-left:18px;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:14px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{nimi}</h3>
            <p style="color:#888; font-size:13px; line-height:1.7;">{kuvaus}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PALVELUT -->
  <section style="background-color:#1a1a1a; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto; text-align:center;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:18px;">Mitä tuotamme Helsingissä</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; text-align:left;">
        {[
          ['Yritysvideot ja brändivideot', 'Kansainvälisen tason tuotanto pääkaupunkiseudun yrityksille — strategiasta valmiiseen videoon.'],
          ['Rekrytointivideot', 'Helsingissä kilpailu parhaista osaajista on kovinta — rekrytointivideo on investointi joka maksaa itsensä takaisin.'],
          ['Tapahtumavideot', 'Messukeskus, Helsinki-halli, Finlandia-talo — kuvaamme isot tapahtumat ammattitaitoisesti.'],
          ['Kansainväliset tuotannot', 'Englanninkieliset videot kansainvälisille markkinoille — Helsinki on luonteva tuotantopaikka.'],
        ].map(([otsikko, teksti]) => (
          <a href="/varaa/videomarkkinointi" class="pricing-card" style="background:#222; border-radius:4px; padding:20px; gap:10px;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{otsikko}</h3>
            <p style="color:#888; font-size:13px; line-height:1.7;">{teksti}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background-color:#111; padding:60px 20px;" class="faq">
    <div style="max-width:700px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:18px; text-align:center;">Usein kysyttyä — Helsinki</h2>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer;">Mitä videotuotanto maksaa Helsingissä?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Hinnat ovat samat riippumatta kaupungista — yritysvideo alkaen 1 500 €, laajempi kampanja 3 000–8 000 €. Matkakulut Helsinkiin lisätään tarjoukseen. Pitkissä projekteissa sovitaan yöpymisestä tarvittaessa.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer;">Teettekö myös englanninkielisiä tuotantoja?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Kyllä. Englanninkieliset tuotannot kansainvälisille markkinoille onnistuvat. Sovitaan projektikohtaisesti.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer;">Toimiiko videotuotanto myös pääkaupunkiseudun ulkopuolisten yritysten markkinointiin?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Kyllä. Kohderyhmä ratkaisee enemmän kuin kuvauspaikka. Olemme tuottaneet videoita, jotka on kohdennettu Helsinkiin, Tampereelle tai koko Suomeen — sijainnilla ei ole merkitystä sille, kenelle video tehdään.</p>
      </details>
    </div>
  </section>

  <!-- CTA -->
  <section style="background-color:#1a1a1a; padding:60px 20px; text-align:center;">
    <div style="max-width:500px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-6" style="font-size:18px;">Pyydä tarjous — Helsinki</h2>
      <a href="/varaa/videomarkkinointi/?kaupunki=Helsinki" class="btn-white">Pyydä tarjous</a>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section style="background-color:#111; padding:30px 20px; text-align:center;">
    <div style="display:flex; flex-wrap:wrap; gap:16px; justify-content:center;">
      <a href="/videotuotanto/" class="btn-ghost">Videotuotanto koko Suomessa</a>
      <a href="/videotuotanto/jyvaskyla/" class="btn-ghost">Videotuotanto Jyväskylä</a>
      <a href="/videotuotanto/tampere/" class="btn-ghost">Videotuotanto Tampere</a>
    </div>
  </section>

</Layout>
