---
import Layout from '../../../layouts/Layout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Etusivu", "item": "https://ruskamedia.com/" },
    { "@type": "ListItem", "position": 2, "name": "Kiinteistökuvaus", "item": "https://ruskamedia.com/asunto-ja-kiinteistokuvaus/" },
    { "@type": "ListItem", "position": 3, "name": "Kiinteistökuvaus Helsinki", "item": "https://ruskamedia.com/kiinteistokuvaus/helsinki/" }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kiinteistökuvaus Helsinki",
  "serviceType": "Kiinteistövalokuvaus",
  "provider": { "@type": "LocalBusiness", "name": "Ruska Media", "url": "https://ruskamedia.com" },
  "areaServed": { "@type": "City", "name": "Helsinki" },
  "url": "https://ruskamedia.com/kiinteistokuvaus/helsinki/"
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Paljonko kiinteistökuvaus maksaa Helsingissä?", "acceptedAnswer": { "@type": "Answer", "text": "Perusasuntokuvaus alkaa 150 eurosta. Matkakulut Helsinkiin lisätään tarjoukseen. Arvokohteet hinnoitellaan erikseen — pyydä tarjous." }},
    { "@type": "Question", "name": "Kuvaatteko myös muualla pääkaupunkiseudulla?", "acceptedAnswer": { "@type": "Answer", "text": "Kyllä. Espoo, Vantaa ja koko pääkaupunkiseutu. Matkakulut lasketaan etäisyyden mukaan." }},
    { "@type": "Question", "name": "Kuinka nopeasti kuvat toimitetaan?", "acceptedAnswer": { "@type": "Answer", "text": "1–3 arkipäivässä kuvauksesta. Kiiretoimitukset onnistuvat lisämaksusta." }}
  ]
};
---
<Layout
  title="Asuntokuvaus ja kiinteistökuvaus Helsinki — Ruska Estate"
  description="Ammattitaitoinen kiinteistökuvaus Helsingissä — valokuva, drone ja digistailaus. Ruska Estate, yli 1000 asuntoa kuvattuna vuodessa."
  canonical="https://ruskamedia.com/kiinteistokuvaus/helsinki/"
  schema={[breadcrumbSchema, serviceSchema, faqSchema]}
>

  <!-- HERO -->
  <section class="relative w-full overflow-hidden flex items-center justify-center" style="height:500px; background-image:url('https://ruskamedia.com/wp-content/uploads/2022/11/Kiinteistöjen-valokuvaus-Ruska-Media.jpg'); background-size:cover; background-position:center;">
    <div class="absolute inset-0 bg-black" style="opacity:0.55;"></div>
    <div class="relative text-center px-6" style="margin-top:70px; z-index:1;">
      <p style="color:#aaa; font-size:13px; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:12px;">Ruska Estate</p>
      <h1 class="font-heading text-white uppercase tracking-widest font-normal anim-fade-up" style="font-size:38px;">Kiinteistökuvaus Helsinki</h1>
    </div>
  </section>

  <!-- INTRO -->
  <section style="background-color:#1e1e1e; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto; text-align:center;">
      <p style="color:#bbb; font-size:15px; line-height:1.9;">
        Helsinki on Suomen kallein asuntomarkkina — ja juuri siksi kuvauksen merkitys korostuu. Olen nähnyt miten huonosti kuvattu kohde jää pyörimään markkinoille kuukausiksi, kun taas hyvin kuvattu myy nopeasti. Helsingissä se hintaero on konkreettinen: yksi ylimääräinen näyttö voi tarkoittaa kymmeniä tuhansia euroja myyntihinnassa. Pitkä matka ei ole este — kuvauspäivä suunnitellaan tehokkaasti ja majoitus tai matkakulut lisätään tarjoukseen avoimesti.
      </p>
    </div>
  </section>

  <!-- PAIKALLINEN KONTEKSTI -->
  <section style="background-color:#181818; padding:50px 20px;">
    <div style="max-width:800px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest" style="font-size:16px; text-align:center; margin-bottom:28px;">Miksi kuvaus ratkaisee Helsingissä</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
        {[
          ['Töölö, Eira, Ullanlinna', 'Arvokiinteistöt vaativat laadun — näissä kaupunginosissa ostajat vertailevat tarkasti ja kuvat ratkaisevat.'],
          ['Merellinen Helsinki', 'Lauttasaari, Kaivopuisto — drone kertoo merinäkymästä enemmän kuin tuhat sanaa. Pakollinen lisä arvoasunnoissa.'],
          ['Kallio ja Vallila', 'Vuokra-asuntojen nopea kierto — tehokkaat kuvat nopeuttavat vuokrausprosessia merkittävästi.'],
          ['Kalasatama ja Jätkäsaari', 'Uudiskohteiden visualisoinnit ja digistailaus tyhjiin tiloihin — tärkeä osa uuden asunnon markkinointia.'],
        ].map(([otsikko, teksti]) => (
          <div style="padding:20px; background:#222; border-radius:4px; border-top:2px solid #fd8c03;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{otsikko}</h3>
            <p style="color:#888; font-size:13px; line-height:1.7;">{teksti}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PALVELUT -->
  <section style="background-color:#2c2c2c; padding:60px 20px;">
    <div style="max-width:900px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:20px; text-align:center;">Palvelut Helsingissä</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          ['Kiinteistövalokuvaus', 'Sisä- ja ulkokuvat, yksityiskohdat, ammattilaisotteella. Kaikki huoneet samaan hintaan.'],
          ['Ilmakuvaus ja drone', 'Merellinen Helsinki ja pääkaupunkiseudun maisema — dronekuvat laadukkaasti.'],
          ['Digitaalinen sisustus', 'Tyhjät kohteet herätetään eloon digitaalisella sisustuksella.'],
          ['Kiinteistövideo', 'Liikkuvaa kuvaa arvokohteiden ja luksusasuntojen esittelyyn — Helsingissä erityisen kysyttyä.'],
        ].map(([otsikko, teksti]) => (
          <a href="/varaa/kiinteistokuvaus" class="pricing-card" style="background-color:#383838; border-radius:4px; padding:24px; gap:10px;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{otsikko}</h3>
            <p style="color:#999; font-size:14px; line-height:1.7;">{teksti}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background-color:#111; padding:60px 20px;" class="faq">
    <div style="max-width:700px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:20px; text-align:center;">Usein kysyttyä — Helsinki</h2>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Paljonko kiinteistökuvaus maksaa Helsingissä?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Perusasuntokuvaus alkaa 150 eurosta. Matkakulut Helsinkiin lisätään tarjoukseen. Arvokohteet hinnoitellaan erikseen — pyydä tarjous.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Miten kiinteistökuvaus varataan Helsingissä?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Täytä tarjouslomake, kerro kohteen tiedot ja sopiva ajankohta. Vahvistamme kuvauksen yleensä 1–2 arkipäivässä. Kuvaamme Helsingissä, Espoossa, Vantaalla ja koko pääkaupunkiseudulla.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Kuinka nopeasti kuvat toimitetaan?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">1–3 arkipäivässä kuvauksesta. Kiiretoimitukset onnistuvat lisämaksusta.</p>
      </details>
    </div>
  </section>

  <!-- CTA -->
  <section style="background-color:#1a1a1a; padding:60px 20px; text-align:center;">
    <div style="max-width:500px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-6" style="font-size:18px;">Pyydä tarjous — Helsinki</h2>
      <a href="/varaa/kiinteistokuvaus/?kaupunki=Helsinki" class="btn-white">Pyydä tarjous</a>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section style="background-color:#111; padding:30px 20px; text-align:center;">
    <div style="display:flex; flex-wrap:wrap; gap:16px; justify-content:center; font-family:'Dosis',sans-serif; font-size:13px;">
      <a href="/asunto-ja-kiinteistokuvaus/" class="btn-ghost">Ruska Estate pääsivu</a>
      <a href="/kiinteistokuvaus/jyvaskyla/" class="btn-ghost">Kiinteistökuvaus Jyväskylä</a>
      <a href="/kiinteistokuvaus/tampere/" class="btn-ghost">Kiinteistökuvaus Tampere</a>
    </div>
  </section>

</Layout>
