---
import Layout from '../../../layouts/Layout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Etusivu", "item": "https://ruskamedia.com/" },
    { "@type": "ListItem", "position": 2, "name": "Kiinteistökuvaus", "item": "https://ruskamedia.com/asunto-ja-kiinteistokuvaus/" },
    { "@type": "ListItem", "position": 3, "name": "Kiinteistökuvaus Tampere", "item": "https://ruskamedia.com/kiinteistokuvaus/tampere/" }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kiinteistökuvaus Tampere",
  "serviceType": "Kiinteistövalokuvaus",
  "provider": { "@type": "LocalBusiness", "name": "Ruska Media", "url": "https://ruskamedia.com" },
  "areaServed": { "@type": "City", "name": "Tampere" },
  "url": "https://ruskamedia.com/kiinteistokuvaus/tampere/"
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Paljonko kiinteistökuvaus maksaa Tampereella?", "acceptedAnswer": { "@type": "Answer", "text": "Perusasuntokuvaus alkaa 150 eurosta. Matkakulut Tampereelle lisätään tarjoukseen. Pyydä tarjous — lasketaan kohteen mukaan." }},
    { "@type": "Question", "name": "Kuvaatteko myös Pirkanmaan alueella?", "acceptedAnswer": { "@type": "Answer", "text": "Kyllä. Koko Pirkanmaa onnistuu. Matkakulut lasketaan etäisyyden mukaan." }},
    { "@type": "Question", "name": "Kuinka nopeasti kuvat toimitetaan?", "acceptedAnswer": { "@type": "Answer", "text": "1–3 arkipäivässä kuvauksesta. Kiiretoimitukset onnistuvat lisämaksusta." }}
  ]
};
---
<Layout
  title="Asuntokuvaus ja kiinteistökuvaus Tampere — Ruska Estate"
  description="Ammattitaitoinen kiinteistökuvaus Tampereella — valokuva, drone ja digistailaus. Ruska Estate, yli 1000 asuntoa kuvattuna vuodessa."
  canonical="https://ruskamedia.com/kiinteistokuvaus/tampere/"
  schema={[breadcrumbSchema, serviceSchema, faqSchema]}
>

  <!-- HERO -->
  <section class="relative w-full overflow-hidden flex items-center justify-center" style="height:500px; background-image:url('https://ruskamedia.com/wp-content/uploads/2022/10/Kiinteistökuvaus-Ruska-Media.jpg'); background-size:cover; background-position:center;">
    <div class="absolute inset-0 bg-black" style="opacity:0.55;"></div>
    <div class="relative text-center px-6" style="margin-top:70px; z-index:1;">
      <p style="color:#aaa; font-size:13px; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:12px;">Ruska Estate</p>
      <h1 class="font-heading text-white uppercase tracking-widest font-normal anim-fade-up" style="font-size:38px;">Kiinteistökuvaus Tampere</h1>
    </div>
  </section>

  <!-- INTRO -->
  <section style="background-color:#1e1e1e; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto; text-align:center;">
      <p style="color:#bbb; font-size:15px; line-height:1.9;">
        Tampere on yksi Suomen vilkkaimmista asuntomarkkinoista ja kilpailu ostajien huomiosta on kovaa. Olen kuvannut Tampereella kiinteistöjä useita kertoja — näen suoraan miten hyvät kuvat erottavat kohteen joukosta. Neliöhinnat ovat Tampereella sen verran korkeammat, että ammattimainen kuvaus maksaa itsensä takaisin jo yhdessä lisänäytöllä. Matkakulut Jyväskylästä (~1h 40min) lisätään tarjoukseen avoimesti.
      </p>
    </div>
  </section>

  <!-- PAIKALLINEN KONTEKSTI -->
  <section style="background-color:#181818; padding:50px 20px;">
    <div style="max-width:800px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest" style="font-size:16px; text-align:center; margin-bottom:28px;">Miksi kuvaus ratkaisee Tampereella</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
        {[
          ['Rantatunnelin arvokohteet', 'Uudet rakennukset rantatunnelin alueella ovat Tampereen arvokkaimpien joukossa — laatu näkyy kuvissa.'],
          ['Hervannan vuokramarkkina', 'Nopea kierto vaatii tehokkuutta — ammattilaiskuvat nopeuttavat vuokrauksessa ratkaisevasti.'],
          ['Pispalan puutalot', 'Historialliset puutalot vaativat erityistä silmää — tunnelma pitää osata tallentaa oikein.'],
          ['Järvinäkymäkohteet', 'Näsijärvi ja Pyhäjärvi — järveen päin suuntautuva kohde myy paljon paremmin droneilla kuvattuna.'],
        ].map(([otsikko, teksti]) => (
          <div style="padding:20px; background:#222; border-radius:4px; border-top:2px solid #fd8c03;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{otsikko}</h3>
            <p style="color:#888; font-size:13px; line-height:1.7;">{teksti}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PALVELUT -->
  <section style="background-color:#2c2c2c; padding:60px 20px;">
    <div style="max-width:900px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:20px; text-align:center;">Palvelut Tampereella</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          ['Kiinteistövalokuvaus', 'Sisä- ja ulkokuvat, yksityiskohdat, ammattilaisotteella. Kaikki huoneet samaan hintaan.'],
          ['Ilmakuvaus ja drone', 'Tampereen järvimaisemat ja kaupunkikuvaus — dronekuvat laadukkaasti.'],
          ['Digitaalinen sisustus', 'Tyhjät kohteet herätetään eloon digitaalisella sisustuksella.'],
          ['Kiinteistövideo', 'Liikkuvaa kuvaa kohteesta — erityisesti arvokohteiden ja luksusasuntojen esittelyyn.'],
        ].map(([otsikko, teksti]) => (
          <a href="/varaa/kiinteistokuvaus" class="pricing-card" style="background-color:#383838; border-radius:4px; padding:24px; gap:10px;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{otsikko}</h3>
            <p style="color:#999; font-size:14px; line-height:1.7;">{teksti}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background-color:#111; padding:60px 20px;" class="faq">
    <div style="max-width:700px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:20px; text-align:center;">Usein kysyttyä — Tampere</h2>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Paljonko kiinteistökuvaus maksaa Tampereella?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Perusasuntokuvaus alkaa 150 eurosta. Matkakulut Tampereelle lisätään tarjoukseen. Pyydä tarjous — lasketaan kohteen mukaan.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Onnistuuko kiinteistökuvaus myös Tampereen lähikunnissa?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Kyllä. Kuvaamme Tampereella ja koko Pirkanmaalla — Lempäälä, Nokia, Kangasala, Ylöjärvi ja muut lähikunnat. Matkakulut lasketaan etäisyyden mukaan.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Kuinka nopeasti kuvat toimitetaan?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">1–3 arkipäivässä kuvauksesta. Kiiretoimitukset onnistuvat lisämaksusta.</p>
      </details>
    </div>
  </section>

  <!-- CTA -->
  <section style="background-color:#1a1a1a; padding:60px 20px; text-align:center;">
    <div style="max-width:500px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-6" style="font-size:18px;">Pyydä tarjous — Tampere</h2>
      <a href="/varaa/kiinteistokuvaus/?kaupunki=Tampere" class="btn-white">Pyydä tarjous</a>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section style="background-color:#111; padding:30px 20px; text-align:center;">
    <div style="display:flex; flex-wrap:wrap; gap:16px; justify-content:center; font-family:'Dosis',sans-serif; font-size:13px;">
      <a href="/asunto-ja-kiinteistokuvaus/" class="btn-ghost">Ruska Estate pääsivu</a>
      <a href="/kiinteistokuvaus/jyvaskyla/" class="btn-ghost">Kiinteistökuvaus Jyväskylä</a>
      <a href="/kiinteistokuvaus/helsinki/" class="btn-ghost">Kiinteistökuvaus Helsinki</a>
    </div>
  </section>

</Layout>
