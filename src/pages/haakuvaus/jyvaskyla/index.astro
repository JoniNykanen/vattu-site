---
import Layout from '../../../layouts/Layout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Etusivu", "item": "https://ruskamedia.com/" },
    { "@type": "ListItem", "position": 2, "name": "Hääkuvaus", "item": "https://ruskamedia.com/haakuvaus/" },
    { "@type": "ListItem", "position": 3, "name": "Hääkuvaus Jyväskylä", "item": "https://ruskamedia.com/haakuvaus/jyvaskyla/" }
  ]
};
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Hääkuvaus Jyväskylä",
  "alternateName": "Ruska Wedding Frames",
  "serviceType": "Hääkuvaus",
  "description": "Hääkuvaus Jyväskylässä — Joel Nykänen kuvaa häät dokumentaarisesti. Jyväskylä on Joelin kotikaupunki, ei matkakuluja.",
  "provider": { "@type": "LocalBusiness", "name": "Ruska Media", "url": "https://ruskamedia.com" },
  "areaServed": { "@type": "City", "name": "Jyväskylä" },
  "url": "https://ruskamedia.com/haakuvaus/jyvaskyla/"
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Tuleeko matkakustannuksia Jyväskylässä?", "acceptedAnswer": { "@type": "Answer", "text": "Ei. Jyväskylä on kotikaupunkini — kuvaukset täällä eivät sisällä matkakuluja." }},
    { "@type": "Question", "name": "Milloin hääkuvaaja kannattaa varata Jyväskylässä?", "acceptedAnswer": { "@type": "Answer", "text": "12–18 kuukautta etukäteen on realistinen suositus. Kesä- ja elokuun lauantait menevät ensimmäisinä." }},
    { "@type": "Question", "name": "Mitä häätiloja Jyväskylässä suosittelette?", "acceptedAnswer": { "@type": "Answer", "text": "Olen kuvannut Jyväskylässä ja lähialueilla paljon. Kirjoitin tästä oman jutun — löydät suosikkini täältä: ruskamedia.com/blogi/parhaat-haapaikat-jyvaskylassa/" }}
  ]
};
const schema = [breadcrumbSchema, serviceSchema, faqSchema];
---
<Layout
  title="Hääkuvaus Jyväskylä — Ruska Wedding Frames by Joel Nykänen"
  description="Hääkuvaus Jyväskylässä — Joel Nykänen kuvaa häät dokumentaarisesti. Selkeät paketit, ei ennakkomaksuja. Varaa päiväsi."
  canonical="https://ruskamedia.com/haakuvaus/jyvaskyla/"
  schema={schema}
>

  <!-- HERO -->
  <section class="relative w-full overflow-hidden" style="height:500px; background-image:url('https://ruskamedia.com/wp-content/uploads/2022/11/Hääkuvaus-Jyväskylä.jpg'); background-size:cover; background-position:center;">
    <div class="absolute inset-0 bg-black" style="opacity:0.55;"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6" style="z-index:1; margin-top:70px;">
      <p style="color:#aaa; font-size:13px; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:12px;">Ruska Wedding Frames by Joel Nykänen</p>
      <h1 class="font-heading text-white uppercase tracking-widest font-normal anim-fade-up" style="font-size:38px;">Hääkuvaus Jyväskylä</h1>
    </div>
  </section>

  <!-- INTRO -->
  <section style="background-color:#1e1e1e; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto; text-align:center;">
      <p style="color:#bbb; font-size:15px; line-height:1.9;">
        Jyväskylä on kotikaupunkini — tunnen paikat, valot ja vuodenajat. Olen kuvannut häitä täällä vuosia, ja se näkyy siinä miten osaan ajoittaa kuvaukset ja löytää ne paikat, jotka toimivat parhaiten. Jyväskylässä ei tule km-korvauksia, ja saatavuuteni on nopein — pystyn usein reagoimaan lyhyellä varoitusajalla.
      </p>
    </div>
  </section>

  <!-- SIJAINNIT -->
  <section style="background-color:#111; padding:60px 20px;">
    <div style="max-width:800px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest" style="font-size:18px; text-align:center; margin-bottom:36px;">Suosikkipaikkojani Jyväskylässä</h2>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
        {[
          ['Jyväsjärven rantamaisemat', 'Luonnonvalo on parhaimmillaan aamulla ja illalla — järvi tuo syvyyttä kuviin tavalla, jota ei studiossa saa.'],
          ['Alvar Aallon arkkitehtuuri', 'Moderni ja klassinen yhdistyvät Jyväskylässä ainutlaatuisesti. Aallon rakennukset tekevät upeita taustatekstuureita.'],
          ['Lutakko ja satama-alueet', 'Teollinen kaupunkimaisema antaa kontrastin valkoiseen mekkooon — tyylikäs ja urbaani vaihtoehto luontokuville.'],
          ['Muuramen lähimaisemat', 'Maalaismaista rauhaa 15 minuutin ajossa kaupungista. Tuntuu kuin eri maailma — sopii erityisesti syksyn häihin.'],
        ].map(([nimi, kuvaus]) => (
          <div style="border-left:2px solid #fd8c03; padding-left:18px;">
            <h3 style="color:#fff; font-family:'Dosis',sans-serif; font-size:14px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">{nimi}</h3>
            <p style="color:#888; font-size:13px; line-height:1.7;">{kuvaus}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERIA -->
  <section style="background-color:#111; padding:0;">
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:2px;">
      {[
        ['https://ruskamedia.com/wp-content/uploads/2022/11/Hääkuvaus-Jyväskylä.jpg', 'Hääkuvaus Jyväskylässä — Ruska Media'],
        ['https://ruskamedia.com/wp-content/uploads/2020/04/Haapotrettien-valokuvaus.jpg', 'Hääkuvaus luonnossa Jyväskylässä'],
        ['https://ruskamedia.com/wp-content/uploads/2020/04/Haavalokuvaus-Joel-Nykanen.jpg', 'Joel Nykänen hääkuvaaja Jyväskylä'],
      ].map(([src, alt]) => (
        <div style="aspect-ratio:1; overflow:hidden;">
          <img src={src} alt={alt} style="width:100%; height:100%; object-fit:cover;" loading="lazy" />
        </div>
      ))}
    </div>
  </section>

  <!-- PAKETIT -->
  <section style="background-color:#1a1a1a; padding:60px 20px;">
    <div style="max-width:700px; margin:0 auto; text-align:center;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-6" style="font-size:20px;">Hääkuvauspaketit</h2>
      <p style="color:#999; font-size:14px; margin-bottom:32px;">Paketit 500 € – 2 500 €. Ei ennakkomaksua, ei peruutusmaksua yli 30 pv ennen häitä.</p>
      <a href="/haakuvaus/" class="btn-outline">Katso kaikki hääkuvauspaketit</a>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background-color:#111; padding:60px 20px;" class="faq">
    <div style="max-width:700px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-8" style="font-size:20px; text-align:center;">Usein kysyttyä — Jyväskylä</h2>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Tuleeko matkakustannuksia Jyväskylässä?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Ei. Jyväskylä on kotikaupunkini — kuvaukset täällä eivät sisällä matkakuluja.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Milloin hääkuvaaja kannattaa varata Jyväskylässä?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">12–18 kuukautta etukäteen on realistinen suositus. Kesä- ja elokuun lauantait menevät ensimmäisinä.</p>
      </details>
      <details style="border-bottom:1px solid #2a2a2a; padding:16px 0;">
        <summary style="color:#fff; font-family:'Dosis',sans-serif; font-size:15px; font-weight:600; cursor:pointer; list-style:none;">Mitä häätiloja Jyväskylässä suosittelette?</summary>
        <p style="color:#999; font-size:14px; line-height:1.8; margin-top:12px;">Olen kuvannut Jyväskylässä ja lähialueilla paljon. Kirjoitin tästä oman jutun — löydät suosikkini täältä: <a href="/blogi/parhaat-haapaikat-jyvaskylassa/" style="color:#fd8c03; text-decoration:none;">Parhaat hääpaikat Jyväskylässä</a></p>
      </details>
    </div>
  </section>

  <!-- CTA -->
  <section style="background-color:#1a1a1a; padding:60px 20px; text-align:center;">
    <div style="max-width:500px; margin:0 auto;">
      <h2 class="font-heading text-white uppercase tracking-widest mb-6" style="font-size:18px;">Varaa hääkuvaus Jyväskylässä</h2>
      <a href="/varaa/haakuvaus/?kaupunki=Jyv%C3%A4skyl%C3%A4" class="btn-white">Varaa hääkuvaus</a>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section style="background-color:#111; padding:30px 20px; text-align:center;">
    <div style="display:flex; flex-wrap:wrap; gap:16px; justify-content:center; font-family:'Dosis',sans-serif; font-size:13px;">
      <a href="/haakuvaus/" class="btn-ghost">Hääkuvaus koko Suomessa</a>
      <a href="/haakuvaus/tampere/" class="btn-ghost">Hääkuvaus Tampere</a>
      <a href="/haakuvaus/helsinki/" class="btn-ghost">Hääkuvaus Helsinki</a>
      <a href="/haakuvaus/turku/" class="btn-ghost">Hääkuvaus Turku</a>
    </div>
  </section>

</Layout>
