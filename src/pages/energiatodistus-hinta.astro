---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Energiatodistus hinta 2026, FISE-pätevä LVI-insinööri | Vattu Oy"
  description="Energiatodistuksen hinta omakotitaloon, rivitaloon tai kerrostaloon. FISE ylempi taso. Nopea toimitus. Uusimaa, Pirkanmaa, Keski-Suomi. Pyydä tarjous."
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Energiatodistus",
    "provider": {
      "@type": "LocalBusiness",
      "name": "LVI-insinööritoimisto Vattu Oy",
      "url": "https://vattu.fi",
      "email": "oskari@vattu.fi",
      "telephone": "+358407656096"
    },
    "areaServed": ["Uusimaa","Pirkanmaa","Keski-Suomi"],
    "description": "Energiatodistuksen laadinta asuinrakennuksille ja toimitiloille. FISE ylempi taso."
  })} />

  <!-- Hero -->
  <section class="bg-forest relative">
    <div class="w-full">
      <div class="flex flex-col justify-center px-8 lg:px-12 xl:px-16 py-14 lg:py-20">
        <p class="font-body text-[10px] tracking-[0.22em] uppercase text-white/55 mb-5">Palvelu · Energiatodistus</p>
        <h1 class="font-heading text-white leading-[1.05] mb-5" style="font-size: clamp(1.75rem, 3.5vw, 3rem);">
          Energiatodistus<br />Hinta ja tilaus
        </h1>
        <div class="w-6 h-px bg-white/15 mb-6"></div>
        <p class="font-body text-sm text-white/55 leading-relaxed mb-8 max-w-[400px]">
          Myyntiä, vuokrausta tai rakennuslupaa varten. Laadin todistuksen FISE ylempi taso -pätevyydellä. Oikein ensimmäisellä kerralla.
        </p>
        <a href="#yhteydenotto" class="inline-block w-max font-body text-[11px] tracking-[0.18em] uppercase text-white border border-accent/50 px-8 py-4 hover:bg-accent hover:border-accent transition-colors duration-300 active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-forest">
          Varaa etäpalaveri
        </a>
      </div>
    </div>
  </section>

  <!-- Wave -->
  <div class="bg-forest overflow-hidden leading-none -mt-px -mb-px">
    <svg viewBox="0 0 1440 72" preserveAspectRatio="none" class="w-full block h-10 lg:h-14" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,36 C240,72 480,0 720,36 C960,72 1200,0 1440,36 L1440,72 L0,72 Z" fill="#F4F0E8" />
    </svg>
  </div>

  <!-- Loss framing -->
  <section class="bg-cream pt-10 lg:pt-16 pb-0">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <div class="p-5 bg-forest/5 ring-1 ring-forest/10 rounded-xl">
        <p class="font-body text-sm text-[#1A1A1A]/70 leading-relaxed">
          <strong class="text-[#1A1A1A]">Puuttuva energiatodistus voi johtaa uhkasakkoon: omakotitalossa 800 €, kerrostalossa jopa 6 000 €.</strong> Varke valvoo velvoitteen noudattamista. Todistuksen teettäminen on huomattavasti edullisempaa.
        </p>
      </div>
    </div>
  </section>

  <!-- Osio 1: Hintataulukko -->
  <section class="bg-cream py-12 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-6">Hinnasto 2026</span>
      <h2 class="font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-4">Energiatodistuksen hinta rakennustyypeittäin</h2>
      <p class="font-body text-sm text-[#1A1A1A]/60 leading-relaxed mb-8">
        Hinnat sisältävät laskennan, todistuksen laadinnan ja rekisteröinnin Varken energiatodistusrekisteriin.
      </p>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-[#1A1A1A]/10">
              <th class="text-left font-body text-[10px] tracking-[0.18em] uppercase text-[#1A1A1A]/35 py-3 pr-6">Rakennustyyppi</th>
              <th class="text-right font-body text-[10px] tracking-[0.18em] uppercase text-[#1A1A1A]/35 py-3">Hinta-arvio</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#1A1A1A]/8">
            {[
              ['Omakotitalo / paritalo (uudiskohde, etälaskenta)', '229–290 €'],
              ['Omakotitalo / paritalo (olemassa oleva, kohdekäynti)', '299–500 €'],
              ['Rivitalo', '300–600 €'],
              ['Kerrostalo (pieni taloyhtiö)', '650–860 €'],
              ['Toimisto / liiketila', '500–1 000 €'],
            ].map(([type, price]) => (
              <tr>
                <td class="font-body text-sm text-[#1A1A1A]/70 py-4 pr-6 leading-snug">{type}</td>
                <td class="font-heading text-[#1A1A1A] text-sm py-4 text-right whitespace-nowrap">{price}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="font-body text-sm text-[#1A1A1A]/50 leading-relaxed mt-6">
        Pyydä tarkka tarjous kohteellesi: <a href="#yhteydenotto" class="underline underline-offset-2 hover:text-forest transition-colors">varaa ilmainen etäpalaveri</a> tai lähetä sähköpostia.
      </p>
    </div>
  </section>

  <!-- Osio 2: Mikä vaikuttaa hintaan -->
  <section class="bg-forest py-12 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-white/10 text-white/50 mb-6">Hinnanmuodostus</span>
      <h2 class="font-heading text-white text-2xl lg:text-3xl mb-10">Mikä vaikuttaa energiatodistuksen hintaan</h2>
      <p class="font-body text-sm text-white/50 leading-relaxed mb-10">Hintaero selittyy kolmella asialla.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: 'Kohdekäynti vai etälaskenta',
            body: 'Olemassa olevan rakennuksen energiatodistus edellyttää kohdekäyntiä, jossa tarkastetaan rakenteet, ikkunat, lämmitysjärjestelmä ja ilmanvaihto paikan päällä. Uudisrakennuksessa laskenta tehdään suunnitteluasiakirjojen pohjalta, jolloin kohdekäyntiä ei tarvita.',
          },
          {
            title: 'Rakennuksen koko ja monimutkaisuus',
            body: 'Suuremmassa rakennuksessa on enemmän rakennetyyppejä, järjestelmiä ja laskettavia pinta-aloja. Kerrostalon todistus vie moninkertaisesti enemmän työtä kuin omakotitalon.',
          },
          {
            title: 'Lähtötietojen kattavuus',
            body: 'Mitä valmiimmat tiedot ovat, sitä nopeammin laskenta etenee. Jos piirustukset ja rakennetyypit ovat tallessa, hinta pysyy alakanttia. Jos tietoja puuttuu, joudutaan käyttämään oletusarvoja. Tulos on usein heikompi ja työmäärä kasvaa.',
          },
        ].map(item => (
          <div class="p-1.5 bg-white/5 ring-1 ring-white/10 rounded-[1.25rem]">
            <div class="bg-forest rounded-[calc(1.25rem-6px)] p-6 h-full">
              <h3 class="font-heading text-white text-base mb-3">{item.title}</h3>
              <p class="font-body text-sm text-white/55 leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Osio 3: Mitä hinta sisältää -->
  <section class="bg-cream py-12 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-6">Sisältö</span>
      <h2 class="font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-8">Mitä energiatodistuksen hinta sisältää</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div>
          <p class="font-body text-[10px] tracking-[0.16em] uppercase text-[#1A1A1A]/35 mb-4">Aina sisältyy</p>
          <ul class="space-y-3">
            {[
              'Energialaskenta (E-luku ja energialuokka A–G)',
              'Energiatodistuksen laadinta',
              'Rekisteröinti Varken energiatodistusrekisteriin',
              'Toimenpidesuositukset energiatehokkuuden parantamiseksi',
              'Sähköinen allekirjoitus (eIDAS-vaatimusten mukainen)',
            ].map(item => (
              <li class="flex items-start gap-3 font-body text-sm text-[#1A1A1A]/65">
                <span class="mt-0.5 text-forest font-heading text-base leading-none">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p class="font-body text-[10px] tracking-[0.16em] uppercase text-[#1A1A1A]/35 mb-4">Kohdekäynti sisältää lisäksi</p>
          <ul class="space-y-3">
            {[
              'Rakenteiden, ikkunoiden ja talotekniikan tarkastus paikan päällä',
              'Mitattujen tietojen käyttö laskennassa oletusarvojen sijaan. Tulos on tarkempi.',
            ].map(item => (
              <li class="flex items-start gap-3 font-body text-sm text-[#1A1A1A]/65">
                <span class="mt-0.5 text-forest font-heading text-base leading-none">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Osio 4: Milloin pakollinen -->
  <section class="bg-cream border-t border-[#1A1A1A]/8 py-12 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-6">Pakollinen vai ei</span>
      <h2 class="font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-4">Milloin energiatodistus on pakollinen</h2>
      <p class="font-body text-sm text-[#1A1A1A]/60 leading-relaxed mb-8">Energiatodistuksen hankkiminen on rakennuksen omistajan vastuulla.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        {[
          { title: 'Myynti', body: 'Energiatehokkuusluokka on ilmoitettava myynti-ilmoituksessa. Todistus on oltava nähtävillä esittelyissä ja annettava ostajalle kaupan yhteydessä.' },
          { title: 'Vuokraus', body: 'Sama velvoite kuin myynnissä. Energiatehokkuusluokka näkyy vuokrausilmoituksessa ja todistus esitetään vuokralaiselle.' },
          { title: 'Uudisrakentaminen', body: 'Energiatodistus laaditaan rakennuslupavaiheessa osana energiaselvitystä. Lupa ei etene ilman sitä.' },
        ].map(item => (
          <div class="border-l-2 border-forest/25 pl-5">
            <h3 class="font-heading text-[#1A1A1A] text-base mb-2">{item.title}</h3>
            <p class="font-body text-sm text-[#1A1A1A]/60 leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>

      <div class="bg-forest/5 ring-1 ring-forest/10 rounded-xl p-6">
        <p class="font-body text-[10px] tracking-[0.16em] uppercase text-[#1A1A1A]/35 mb-3">Poikkeukset: todistusta ei vaadita</p>
        <ul class="space-y-2">
          {[
            'Rakennus on enintään 50 m²',
            'Loma-asunto, jota käytetään enintään 4 kuukautta vuodessa eikä majoitustoiminnassa',
            'Tilapäinen rakennus (suunniteltu käyttöaika enintään 2 vuotta)',
            'Teollisuus- ja korjaamorakennukset',
          ].map(item => (
            <li class="flex items-start gap-3 font-body text-sm text-[#1A1A1A]/60">
              <span class="mt-1.5 w-1 h-1 rounded-full bg-forest/40 shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Osio 5: Miksi FISE ylempi taso -->
  <section class="bg-forest py-12 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-white/10 text-white/50 mb-6">FISE ylempi taso</span>
      <h2 class="font-heading text-white text-2xl lg:text-3xl mb-6">Miksi valita FISE ylemmän tason pätevyydellä</h2>
      <p class="font-body text-sm text-white/55 leading-relaxed mb-6">
        Energiatodistuksen saa laatia vain pätevöitynyt ammattilainen, joka on rekisteröity Varken energiatodistusrekisteriin. Pätevyyksiä on kaksi tasoa.
      </p>
      <p class="font-body text-sm text-white/85 leading-relaxed mb-8">
        Minulla on <strong class="text-white font-medium">FISE ylempi taso</strong>, korkein saatavilla oleva pätevyysluokka. Se kattaa sekä tavanomaiset asuinrakennukset että vaativammat kohteet, joihin perustaso ei riitä.
      </p>
      <ul class="space-y-3">
        {[
          'Todistus on oikeellinen ja hyväksytään rakennusvalvonnassa sekä kiinteistökaupoissa',
          'Dynaaminen laskenta onnistuu tarvittaessa',
          'Ei uusintakierroksia viranomaisten kanssa',
        ].map(item => (
          <li class="flex items-start gap-3 font-body text-sm text-white/65">
            <span class="mt-0.5 text-white/40 font-heading text-base leading-none">✓</span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Osio 6: Lähtötiedot -->
  <section class="bg-cream py-12 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-6">Lähtötiedot</span>
      <h2 class="font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-4">Mitä tietoja energiatodistuksen laadintaan tarvitaan</h2>
      <p class="font-body text-sm text-[#1A1A1A]/60 leading-relaxed mb-8">Laskenta sujuu nopeimmin, kun nämä tiedot ovat valmiina:</p>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-6">
        {[
          'Pohja- ja leikkauspiirustukset',
          'Rakennetyypit (seinä, yläpohja, alapohja) tai rakennusvuosi',
          'Lämmitysjärjestelmän tiedot (lämmitystapa, laitemalli)',
          'Ilmanvaihtokone ja lämmöntalteenoton hyötysuhde',
          'Ikkunoiden koko ja tyyppi',
          'Lämmitetty nettoala tai bruttoala',
        ].map(item => (
          <li class="flex items-start gap-3 font-body text-sm text-[#1A1A1A]/65">
            <span class="mt-1.5 w-1 h-1 rounded-full bg-forest/40 shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
      <p class="font-body text-sm text-[#1A1A1A]/50 leading-relaxed">
        Jos tietoja ei ole tallessa, ei hätää. Olemassa olevan rakennuksen kohdekäynnillä tarvittavat tiedot tarkastetaan paikan päällä.
      </p>
    </div>
  </section>

  <!-- Osio 7: FAQ -->
  <section class="bg-cream border-t border-[#1A1A1A]/8 py-12 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-6">Usein kysyttyä</span>
      <h2 class="font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-8">Usein kysyttyä energiatodistuksen hinnasta</h2>
      <div class="accordion divide-y divide-[#1A1A1A]/12">
        {[
          {
            q: 'Kuinka kauan energiatodistus on voimassa?',
            a: 'Energiatodistus on voimassa 10 vuotta laatimispäivästä. Todistus kannattaa uusia, jos rakennus on peruskorjattu ja energiatehokkuus on parantunut selvästi.',
          },
          {
            q: 'Voiko energiatodistuksen tehdä itse?',
            a: 'Ei. Energiatodistuksen voi laatia vain pätevöitynyt, Varken rekisteriin merkitty ammattilainen. Itse laadittu todistus ei ole pätevä.',
          },
          {
            q: 'Mitä eroa on energiatodistuksella ja energiaselvityksellä?',
            a: 'Energiatodistus on asiakirja myyntiä ja vuokrausta varten. Energiaselvitys on laajempi kokonaisuus rakennuslupaa varten. Se sisältää energiatodistuksen, tasauslaskennan ja muut viranomaisliitteet. Uudisrakennuksessa laaditaan aina energiaselvitys, johon energiatodistus sisältyy.',
          },
          {
            q: 'Mitä tapahtuu, jos energiatodistus puuttuu myyntitilanteessa?',
            a: 'Varke valvoo velvoitteen noudattamista. Puuttuvasta todistuksesta voi seurata uhkasakko: omakotitalosta 800 €, kerrostalosta 4 000–6 000 €.',
          },
          {
            q: 'Vaikuttaako energiatodistus asunnon myyntihintaan?',
            a: 'Ei suoraan lakiteknisesti, mutta käytännössä kyllä. A- tai B-luokan rakennus on markkinoilla parempi verrattuna F-luokkaan. Ostajat ja kiinteistönvälittäjät osaavat lukea energialuokan.',
          },
        ].map((item, i) => (
          <div class="faq-item" data-open={i === 0 ? 'true' : 'false'}>
            <button class="faq-trigger w-full flex items-center justify-between py-5 text-left font-body text-[#1A1A1A] hover:text-forest transition-colors" aria-expanded={i === 0 ? 'true' : 'false'}>
              <span class="text-sm pr-6">{item.q}</span>
              <span class="faq-icon text-xl leading-none select-none shrink-0">{i === 0 ? '−' : '+'}</span>
            </button>
            <div class="faq-panel overflow-hidden transition-[max-height] duration-300" style={i === 0 ? '' : 'max-height:0'}>
              <p class="font-body text-sm text-[#1A1A1A]/65 leading-relaxed pb-5">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Osio 8: Palvelualue -->
  <section class="bg-forest py-10 lg:py-14">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12 text-center">
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-white/10 text-white/50 mb-5">Palvelualue</span>
      <p class="font-body text-sm text-white/65 leading-relaxed mx-auto">
        Laadin energiatodistuksia ja energiaselvityksiä <strong class="text-white font-medium">Uudellamaalla</strong> (Helsinki, Espoo, Vantaa ja ympäristökunnat), <strong class="text-white font-medium">Pirkanmaalla</strong> (Tampere ja lähikunnat) sekä <strong class="text-white font-medium">Keski-Suomessa</strong> (Jyväskylä ja ympäristö).
      </p>
    </div>
  </section>

  <!-- Wave -->
  <div class="bg-forest overflow-hidden leading-none -mb-px">
    <svg viewBox="0 0 1440 72" preserveAspectRatio="none" class="w-full block h-10 lg:h-14" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,36 C240,0 480,72 720,36 C960,0 1200,72 1440,36 L1440,72 L0,72 Z" fill="#F4F0E8" />
    </svg>
  </div>

  <!-- Yhteydenotto -->
  <section id="yhteydenotto" class="bg-cream pt-10 pb-24 lg:py-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12 text-center">
      <div class="flex justify-center mb-3"><span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55">Yhteydenotto</span></div>
      <h2 class="font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-10">Kerro rakennustyyppi ja pinta-ala, niin saat tarkan hinnan saman päivän aikana.</h2>

      <!-- Desktop kalenteri -->
      <div class="hidden lg:block border border-[#1A1A1A]/8 overflow-hidden shadow-sm mb-8">
        <div class="bg-forest/5 border-b border-[#1A1A1A]/8 px-5 py-3 flex items-center gap-3">
          <div class="w-2 h-2 rounded-full bg-forest/40"></div>
          <span class="font-body text-[11px] tracking-[0.14em] uppercase text-[#1A1A1A]/35">Ilmainen etäpalaveri 30 min</span>
        </div>
        <iframe src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0EiCYaQeHPOreKXBXVhRlFcn7Ag2rVd6PC4938WN1oFasif4wKNPu8jUwBSsfZKMKPWs0oqAld?gv=true&hl=fi" style="border:0;display:block;" width="100%" height="550" frameborder="0" title="Varaa etäpalaveri"></iframe>
      </div>
      <div class="lg:hidden mb-6">
        <a href="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0EiCYaQeHPOreKXBXVhRlFcn7Ag2rVd6PC4938WN1oFasif4wKNPu8jUwBSsfZKMKPWs0oqAld?gv=true&hl=fi" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between w-full bg-forest text-white px-6 py-5 active:scale-[0.98] transition-transform">
          <div>
            <p class="font-body text-[10px] tracking-[0.18em] uppercase text-white/50 mb-1">Ilmainen · 30 min · Google Meet</p>
            <p class="font-heading text-lg">Varaa etäpalaveri</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
      </div>

      <!-- Suorat yhteystiedot -->
      <div class="text-center mt-12">
        <p class="font-heading text-[#1A1A1A] text-lg mb-6">
          Soita, lähetä sähköpostia tai ota yhteyttä WhatsAppissa.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
