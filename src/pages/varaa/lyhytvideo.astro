---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Kysy tarjous — Lyhytvideo yrityksille | Ruska Media"
  description="Kysy tarjous lyhytvideotuotannosta. Täytä lomake niin otamme yhteyttä."
  canonical="https://ruskamedia.com/varaa/lyhytvideo/"
  noindex={true}
>
  <section style="background-color:#111; padding:100px 20px 60px; text-align:center; border-bottom:1px solid #1e1e1e;">
    <p style="font-family:'Dosis',sans-serif; font-size:12px; text-transform:uppercase; letter-spacing:0.2em; color:#666; margin-bottom:12px;">TikTok · Instagram Reels · YouTube Shorts</p>
    <h1 class="font-heading text-white uppercase tracking-widest font-normal anim-fade-up" style="font-size:32px; margin-bottom:16px; text-wrap:balance;">Kysy tarjous — Lyhytvideo</h1>
    <p style="color:#888; font-size:14px; font-family:'Dosis',sans-serif; max-width:480px; margin:0 auto;">Kerro projektistasi ja saat tarjouksen 1–2 arkipäivässä.</p>
  </section>

  <section style="background-color:#111; padding:60px 0 80px;">
    <div style="max-width:680px; margin:0 auto; padding:0 20px;">
      <form method="POST" action="/api/varaus/lyhytvideo">

        <div style="margin-bottom:32px;">
          <p style="font-family:'Dosis',sans-serif; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; color:#888; margin-bottom:20px; padding-bottom:10px; border-bottom:1px solid #2a2a2a;">Yrityksen tiedot</p>

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:18px;">
            <div>
              <label for="lv-nimi" style="display:block; font-family:'Dosis',sans-serif; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#aaa; margin-bottom:7px;">Nimi <span style="color:#fd8c03;">*</span></label>
              <input type="text" id="lv-nimi" name="nimi" required placeholder="Etunimi Sukunimi" autocomplete="name" style="width:100%; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:4px; color:#fff; font-family:'Dosis',sans-serif; font-size:15px; padding:12px 16px; box-sizing:border-box;" />
            </div>
            <div>
              <label for="lv-yritys" style="display:block; font-family:'Dosis',sans-serif; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#aaa; margin-bottom:7px;">Yritys</label>
              <input type="text" id="lv-yritys" name="yritys" placeholder="Yrityksen nimi" autocomplete="organization" style="width:100%; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:4px; color:#fff; font-family:'Dosis',sans-serif; font-size:15px; padding:12px 16px; box-sizing:border-box;" />
            </div>
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:18px;">
            <div>
              <label for="lv-email" style="display:block; font-family:'Dosis',sans-serif; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#aaa; margin-bottom:7px;">Sähköposti <span style="color:#fd8c03;">*</span></label>
              <input type="email" id="lv-email" name="email" required placeholder="sinä@yritys.fi" autocomplete="email" spellcheck="false" style="width:100%; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:4px; color:#fff; font-family:'Dosis',sans-serif; font-size:15px; padding:12px 16px; box-sizing:border-box;" />
            </div>
            <div>
              <label for="lv-puhelin" style="display:block; font-family:'Dosis',sans-serif; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#aaa; margin-bottom:7px;">Puhelin</label>
              <input type="tel" id="lv-puhelin" name="puhelin" placeholder="040 123 4567" autocomplete="tel" inputmode="tel" style="width:100%; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:4px; color:#fff; font-family:'Dosis',sans-serif; font-size:15px; padding:12px 16px; box-sizing:border-box;" />
            </div>
          </div>
        </div>

        <div style="margin-bottom:32px;">
          <p style="font-family:'Dosis',sans-serif; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; color:#888; margin-bottom:20px; padding-bottom:10px; border-bottom:1px solid #2a2a2a;">Projektin tiedot</p>

          <div style="margin-bottom:18px;">
            <fieldset style="border:none; padding:0; margin:0;">
              <legend style="color:#aaa; font-size:12px; font-family:'Dosis',sans-serif; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:7px;">Kanavat</legend>
              <div style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:4px;">
                {['TikTok', 'Instagram Reels', 'YouTube Shorts', 'LinkedIn', 'Muu'].map(kanava => (
                  <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-family:'Dosis',sans-serif; font-size:13px; color:#aaa; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:25px; padding:8px 16px;">
                    <input type="checkbox" name="kanavat" value={kanava} style="width:auto;" />
                    {kanava}
                  </label>
                ))}
              </div>
            </fieldset>
          </div>

          <div style="margin-bottom:18px;">
            <label for="lv-maara" style="display:block; font-family:'Dosis',sans-serif; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#aaa; margin-bottom:7px;">Videoiden määrä (arvio)</label>
            <select id="lv-maara" name="maara" autocomplete="off" style="width:100%; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:4px; color:#fff; font-family:'Dosis',sans-serif; font-size:15px; padding:12px 16px;">
              <option value="">Valitse...</option>
              <option value="1 video">1 video (yksittäinen)</option>
              <option value="2–5 videota">2–5 videota</option>
              <option value="Kuukausipaketti">Kuukausipaketti (jatkuva)</option>
              <option value="En ole varma">En ole vielä varma</option>
            </select>
          </div>

          <div style="margin-bottom:18px;">
            <label for="lv-paikkakunta" style="display:block; font-family:'Dosis',sans-serif; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#aaa; margin-bottom:7px;">Kuvauspaikkakunta</label>
            <input type="text" id="lv-paikkakunta" name="paikkakunta" placeholder="esim. Jyväskylä" autocomplete="off" style="width:100%; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:4px; color:#fff; font-family:'Dosis',sans-serif; font-size:15px; padding:12px 16px; box-sizing:border-box;" />
          </div>

          <div>
            <label for="lv-kuvaus" style="display:block; font-family:'Dosis',sans-serif; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#aaa; margin-bottom:7px;">Kerro projektistasi <span style="color:#fd8c03;">*</span></label>
            <textarea id="lv-kuvaus" name="kuvaus" required rows="5" placeholder="Mitä halutaan kuvata, mikä on tavoite, kohderyhmä, tyyli…" autocomplete="off" style="width:100%; background:#1e1e1e; border:1px solid #2a2a2a; border-radius:4px; color:#fff; font-family:'Dosis',sans-serif; font-size:15px; padding:12px 16px; box-sizing:border-box; resize:vertical;"></textarea>
          </div>
        </div>

                <div style="text-align:center; margin-top:48px;">

          <!-- Nappi -->
          <button type="submit" class="btn-submit" style="touch-action:manipulation;">
            Lähetä tarjouspyyntö
          </button>

          <!-- Yhteystiedot -->
          <div style="margin-top:32px; padding:24px 28px; background:#1a1a1a; border:1px solid #2a2a2a; border-radius:4px; max-width:480px; margin-left:auto; margin-right:auto; margin-top:32px;">
            <p style="font-family:'Dosis',sans-serif; font-size:11px; text-transform:uppercase; letter-spacing:0.15em; color:#555; margin-bottom:14px;">Herääkö kysymyksiä?</p>
            <div style="display:flex; flex-direction:column; gap:10px;">
              <a href="mailto:joel@ruskamedia.com" style="font-family:'Dosis',sans-serif; font-size:14px; color:#ccc; text-decoration:none; display:flex; justify-content:space-between; align-items:center;">
                <span style="color:#888;">Joel Nykänen</span>
                <span>joel@ruskamedia.com</span>
              </a>
              <a href="mailto:oskari@ruskamedia.com" style="font-family:'Dosis',sans-serif; font-size:14px; color:#ccc; text-decoration:none; display:flex; justify-content:space-between; align-items:center;">
                <span style="color:#888;">Oskari Vattu</span>
                <span>oskari@ruskamedia.com</span>
              </a>
            </div>
          </div>

        </div>

      </form>
    </div>
  </section>
</Layout>
