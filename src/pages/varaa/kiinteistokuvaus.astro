---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Varaa kiinteistökuvaus — Ruska Estate | Ruska Media"
  description="Varaa kiinteistökuvaus Ruska Estatelta — valokuva, drone tai digistailaus. Täytä lomake niin otamme yhteyttä."
  canonical="https://ruskamedia.com/varaa/kiinteistokuvaus/"
  noindex={true}
>

<style>
  .form-wrap { max-width: 780px; margin: 0 auto; padding: 0 20px 80px; }
  .form-section { margin-bottom: 40px; }
  .form-section h2 {
    font-family: 'Dosis', sans-serif; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.15em; color: #888;
    margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid #2a2a2a;
  }
  .field { margin-bottom: 18px; }
  label {
    display: block; font-family: 'Dosis', sans-serif; font-size: 12px;
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;
    color: #aaa; margin-bottom: 7px;
  }
  input[type="text"], input[type="email"], input[type="tel"], select, textarea {
    width: 100%; background-color: #1e1e1e; border: 1px solid #2a2a2a;
    border-radius: 4px; color: #fff; font-family: 'Dosis', sans-serif;
    font-size: 15px; padding: 12px 16px; outline: none;
    transition: border-color 0.2s; box-sizing: border-box;
  }
  input:focus-visible, select:focus-visible, textarea:focus-visible {
    border-color: #fd8c03;
    outline: 2px solid rgba(253, 140, 3, 0.7);
    outline-offset: 0;
  }
  textarea { resize: vertical; min-height: 100px; }
  select option { background-color: #1e1e1e; }

  /* Radio/checkbox cards */
  .option-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .option-card { position: relative; }
  .option-card input { position: absolute; opacity: 0; width: 0; }
  .option-label {
    display: flex; justify-content: space-between; align-items: center;
    background-color: #1e1e1e; border: 1px solid #2a2a2a; border-radius: 4px;
    padding: 14px 18px; cursor: pointer; transition: border-color 0.2s, background-color 0.2s;
  }
  .option-card input:checked + .option-label { border-color: #fff; background-color: #2a2a2a; }
  .option-label:hover { border-color: #444; }
  .option-label:focus-within {
    outline: 2px solid #fd8c03;
    outline-offset: 2px;
  }
  .option-name { font-family: 'Dosis', sans-serif; font-size: 14px; font-weight: 600; color: #fff; text-transform: uppercase; letter-spacing: 0.05em; }
  .option-sub { font-size: 12px; color: #666; margin-top: 3px; }

  /* Service checkboxes */
  .service-grid { display: flex; flex-direction: column; gap: 10px; }
  .svc-card { position: relative; }
  .svc-card input[type="checkbox"] { position: absolute; opacity: 0; width: 0; }
  .svc-label {
    display: flex; justify-content: space-between; align-items: center;
    background-color: #1e1e1e; border: 1px solid #2a2a2a; border-radius: 4px;
    padding: 16px 20px; cursor: pointer; transition: border-color 0.2s, background-color 0.2s;
  }
  .svc-card input:checked + .svc-label { border-color: #fff; background-color: #2a2a2a; }
  .svc-label:hover { border-color: #444; }
  .svc-name { font-family: 'Dosis', sans-serif; font-size: 14px; font-weight: 600; color: #fff; text-transform: uppercase; letter-spacing: 0.05em; }
  .svc-desc { font-size: 12px; color: #777; margin-top: 4px; }

  .price-box {
    background-color: #1e1e1e; border: 1px solid #2a2a2a; border-radius: 4px;
    padding: 20px 24px; margin-top: 24px;
  }
  .price-row {
    display: flex; justify-content: space-between;
    font-family: 'Dosis', sans-serif; font-size: 13px; color: #888; margin-bottom: 8px;
  }
  .price-row.total {
    font-size: 18px; font-weight: 700; color: #fff;
    border-top: 1px solid #333; padding-top: 12px; margin-top: 8px;
  }
  .price-row span:last-child { color: #fff; }
  .price-note { font-size: 11px; color: #555; margin-top: 10px; font-family: 'Dosis', sans-serif; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 600px) { .option-grid, .two-col { grid-template-columns: 1fr; } }
  .required { color: #fd8c03; }
  .submit-row { text-align: center; margin-top: 40px; }
  .notice { font-family: 'Dosis', sans-serif; font-size: 12px; color: #555; margin-top: 16px; text-align: center; }
  .discount-badge {
    display: inline-block; background-color: #2a2a2a; color: #fd8c03;
    font-family: 'Dosis', sans-serif; font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.1em; padding: 4px 10px; border-radius: 20px; margin-top: 12px;
  }
</style>

  <!-- HERO -->
  <section style="background-color:#111; padding:100px 20px 60px; text-align:center; border-bottom:1px solid #1e1e1e;">
    <p style="font-family:'Dosis',sans-serif; font-size:12px; text-transform:uppercase; letter-spacing:0.2em; color:#666; margin-bottom:12px;">Ruska Estate</p>
    <h1 class="font-heading text-white uppercase tracking-widest font-normal anim-fade-up" style="font-size:32px; margin-bottom:16px; text-wrap:balance;">Varaa kiinteistökuvaus</h1>
    <p style="color:#888; font-size:14px; font-family:'Dosis',sans-serif; max-width:480px; margin:0 auto;">Täytä lomake niin otamme yhteyttä 1–2 arkipäivässä ja lähetämme tarjouksen.</p>
  </section>

  <section style="background-color:#111; padding:60px 0;">
    <div class="form-wrap">
      <form id="kiintio-form" method="POST" action="/api/varaus/kiinteistokuvaus">

        <!-- KOHTEEN KOKO -->
        <div class="form-section">
          <h2>1. Kohteen koko</h2>
          <div class="option-grid">
            <div class="option-card">
              <input type="radio" name="koko" id="koko1" value="10–50 m²" required />
              <label class="option-label" for="koko1">
                <div><div class="option-name">10–50 m²</div><div class="option-sub">Yksiö, pieni kaksio</div></div>
              </label>
            </div>
            <div class="option-card">
              <input type="radio" name="koko" id="koko2" value="51–150 m²" />
              <label class="option-label" for="koko2">
                <div><div class="option-name">51–150 m²</div><div class="option-sub">Kaksio, kolmio, rivitalo</div></div>
              </label>
            </div>
            <div class="option-card">
              <input type="radio" name="koko" id="koko3" value="151–250 m²" />
              <label class="option-label" for="koko3">
                <div><div class="option-name">151–250 m²</div><div class="option-sub">Omakotitalo, isompi kohde</div></div>
              </label>
            </div>
            <div class="option-card">
              <input type="radio" name="koko" id="koko4" value="251+ m²" />
              <label class="option-label" for="koko4">
                <div><div class="option-name">251+ m²</div><div class="option-sub">Suuri kohde, liiketila</div></div>
              </label>
            </div>
          </div>
        </div>

        <!-- PALVELUT -->
        <div class="form-section">
          <h2>2. Palvelut</h2>
          <p style="color:#666; font-size:13px; font-family:'Dosis',sans-serif; margin-bottom:16px;">Valitse tarvitsemasi palvelut. Useammasta palvelusta alennus.</p>
          <div class="service-grid">
            <div class="svc-card">
              <input type="checkbox" name="palvelu_valokuva" id="svc1" value="Kiinteistövalokuvaus" />
              <label class="svc-label" for="svc1">
                <div><div class="svc-name">Kiinteistövalokuvaus</div><div class="svc-desc">Sisä- ja ulkokuvat, kaikki huoneet — ammattilaisen otteella</div></div>
              </label>
            </div>
            <div class="svc-card">
              <input type="checkbox" name="palvelu_drone" id="svc2" value="Ilmakuvaus / Drone" />
              <label class="svc-label" for="svc2">
                <div><div class="svc-name">Ilmakuvaus / Drone</div><div class="svc-desc">Dronekuvat ja -videot laadukkaasti, lentolupa sisältyy</div></div>
              </label>
            </div>
            <div class="svc-card">
              <input type="checkbox" name="palvelu_digistailaus" id="svc3" value="Digitaalinen sisustus (digistailaus)" />
              <label class="svc-label" for="svc3">
                <div><div class="svc-name">Digitaalinen sisustus</div><div class="svc-desc">Realistiset sisustukset tyhjiin huoneisiin digitaalisesti</div></div>
              </label>
            </div>
            <div class="svc-card">
              <input type="checkbox" name="palvelu_video" id="svc4" value="Kiinteistövideo" />
              <label class="svc-label" for="svc4">
                <div><div class="svc-name">Kiinteistövideo</div><div class="svc-desc">Liikkuvaa kuvaa maasta ja ilmasta — arvokohteiden esittelyyn</div></div>
              </label>
            </div>
          </div>
          <div id="discount-info" style="display:none;">
            <span class="discount-badge" id="discount-text"></span>
          </div>
          <div style="margin-top:16px; padding:14px 18px; background:#1a1a1a; border-radius:4px; display:none;" id="hinta-arvio">
            <p style="font-family:'Dosis',sans-serif; font-size:12px; color:#777; margin:0;">Hinnoittelu lasketaan tarjouksessa kohteen tietojen perusteella. Saat tarjouksen sähköpostiin 1–2 arkipäivässä.</p>
          </div>
        </div>

        <!-- KOHDE -->
        <div class="form-section">
          <h2>3. Kohteen tiedot</h2>
          <div class="field">
            <label for="kohde_osoite">Kohteen osoite <span class="required">*</span></label>
            <input type="text" name="kohde_osoite" id="kohde_osoite" placeholder="Katuosoite" autocomplete="off" required />
          </div>
          <div class="two-col">
            <div class="field">
              <label for="kohde_postinumero">Postinumero <span class="required">*</span></label>
              <input type="text" name="kohde_postinumero" id="kohde_postinumero" placeholder="00100" autocomplete="off" required />
            </div>
            <div class="field">
              <label for="kohde_kaupunki">Kaupunki <span class="required">*</span></label>
              <input type="text" name="kohde_kaupunki" id="kohde_kaupunki" placeholder="Kaupunki" autocomplete="off" required />
            </div>
          </div>
          <div class="field">
            <label for="huoneisto">Huoneiston numero</label>
            <input type="text" name="huoneisto" id="huoneisto" placeholder="esim. A 12" autocomplete="off" />
          </div>
          <div class="field">
            <label for="kuvauspref">Toivottu kuvauspäivä / -aika</label>
            <input type="text" name="kuvauspref" id="kuvauspref" placeholder="esim. arkisin aamupäivisin, tai ma 12.5." autocomplete="off" />
          </div>
        </div>

        <!-- ASIAKASTIEDOT -->
        <div class="form-section">
          <h2>4. Yhteystiedot</h2>
          <div class="two-col">
            <div class="field">
              <label for="nimi">Nimi <span class="required">*</span></label>
              <input type="text" name="nimi" id="nimi" placeholder="Etunimi Sukunimi" autocomplete="name" required />
            </div>
            <div class="field">
              <label for="yritys">Yritys</label>
              <input type="text" name="yritys" id="yritys" placeholder="Yrityksen nimi (valinnainen)" autocomplete="organization" />
            </div>
          </div>
          <div class="two-col">
            <div class="field">
              <label for="email">Sähköposti <span class="required">*</span></label>
              <input type="email" name="email" id="email" placeholder="sinä@email.fi" autocomplete="email" spellcheck="false" required />
            </div>
            <div class="field">
              <label for="puhelin">Puhelin <span class="required">*</span></label>
              <input type="tel" name="puhelin" id="puhelin" placeholder="040 123 4567" autocomplete="tel" inputmode="tel" required />
            </div>
          </div>
        </div>

        <!-- LISÄTIEDOT -->
        <div class="form-section">
          <h2>5. Lisätiedot</h2>
          <div class="field">
            <label for="lisatiedot">Muuta kerrottavaa</label>
            <textarea name="lisatiedot" id="lisatiedot" placeholder="Erikoistoiveet, kohteen erityispiirteet, kysymykset…" autocomplete="off"></textarea>
          </div>
        </div>

        <div class="submit-row">
          <button type="submit" class="btn-white" style="border:none; cursor:pointer; font-family:'Dosis',sans-serif; touch-action:manipulation;">
            Lähetä tarjouspyyntö
          </button>
          <p class="notice">Saat tarjouksen sähköpostiin 1–2 arkipäivässä</p>
          <p class="notice">Km-korvaukset Jyväskylän ulkopuolelle (€0,45/km yli 50 km) lisätään tarjoukseen</p>
        </div>

      </form>
    </div>
  </section>

</Layout>

<script>
  // Esitäytä kaupunki URL-parametrista
  const params = new URLSearchParams(window.location.search);
  const kaupunkiParam = params.get('kaupunki');
  if (kaupunkiParam) {
    const kentta = document.getElementById('kohde_kaupunki') as HTMLInputElement;
    if (kentta) kentta.value = kaupunkiParam;
  }

  const checkboxes = document.querySelectorAll('input[name^="palvelu_"]');
  const discountInfo = document.getElementById('discount-info');
  const discountText = document.getElementById('discount-text');
  const hintaArvio = document.getElementById('hinta-arvio');

  function updateDiscount() {
    const checked = Array.from(checkboxes).filter((cb) => (cb as HTMLInputElement).checked).length;
    if (checked >= 2) {
      discountInfo!.style.display = 'block';
      hintaArvio!.style.display = 'block';
      if (checked === 2) discountText!.textContent = '10% volyymialennus kahdesta palvelusta';
      if (checked >= 3) discountText!.textContent = '20% volyymialennus kolmesta palvelusta';
    } else {
      discountInfo!.style.display = 'none';
      hintaArvio!.style.display = checked > 0 ? 'block' : 'none';
    }
  }

  checkboxes.forEach(cb => cb.addEventListener('change', updateDiscount));
</script>
