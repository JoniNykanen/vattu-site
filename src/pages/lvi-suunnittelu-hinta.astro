---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/images/lvitaskinen-lvi-suunnttelu-Oulu.webp';
---

<Layout
  title="Paljonko LVI-suunnittelu maksaa? Hinta 2025 | Vattu Oy"
  description="LVI-suunnittelun hinta vaihtelee kohteen koon ja vaativuuden mukaan. Omakotitalo, taloyhtiö, toimitila — hintaesimerkit ja mistä hinta koostuu. Pyydä tarjous."
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Paljonko LVI-suunnittelu maksaa omakotitalossa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Omakotitalon tai pientalon LVI-suunnittelun hinta on tyypillisesti 1 500–4 000 euroa riippuen kohteen koosta ja suunnittelun laajuudesta. Hintaan vaikuttavat muun muassa lämmitysjärjestelmän valinta, ilmanvaihtoratkaisu ja onko kyseessä uudiskohde vai saneeraus."
        }
      },
      {
        "@type": "Question",
        "name": "Paljonko LVI-suunnittelu maksaa taloyhtiössä?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Taloyhtiön linjasaneerauksen tai putkiremontin LVI-suunnittelu alkaa noin 5 000 eurosta. 20 asunnon kerrostalossa hinta on tyypillisesti 7 000–12 000 euroa riippuen laajuudesta ja kokouksista."
        }
      },
      {
        "@type": "Question",
        "name": "Mistä LVI-suunnittelun hinta koostuu?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "LVI-suunnittelun hinta koostuu suunnittelutyöstä, kohteen katselmuksesta, piirustuksista ja asiakirjoista, kokouksista sekä rakennusvalvontaan tehtävistä toimenpiteistä. Hintaan vaikuttavat kohteen koko, käytettävät järjestelmät ja suunnittelun laajuus."
        }
      }
    ]
  })} />

  <!-- Hero -->
  <section class="bg-forest relative">
    <div class="w-full grid grid-cols-1 lg:grid-cols-2 lg:min-h-[55dvh]">
      <div class="flex flex-col justify-center px-8 lg:px-12 xl:px-16 py-14 lg:py-0">
        <p class="font-body text-[10px] tracking-[0.22em] uppercase text-white/55 mb-5">Hinnasto</p>
        <h1 class="font-heading text-white leading-[1.1] mb-5" style="font-size: clamp(1.75rem, 3vw, 2.75rem);">
          Paljonko LVI-suunnittelu maksaa?
        </h1>
        <div class="w-6 h-px bg-white/15 mb-6"></div>
        <p class="font-body text-sm text-white/55 leading-relaxed mb-8 max-w-[400px]">
          Hinta vaihtelee kohteen koon ja laajuuden mukaan. Pientaloista taloyhtiöihin — esimerkkihinnat ja mistä kokonaiskulut koostuvat.
        </p>
        <a href="#yhteydenotto" class="self-start inline-block font-body text-[11px] tracking-[0.18em] uppercase text-white border border-accent/50 px-8 py-4 hover:bg-accent hover:border-accent transition-colors duration-300 active:scale-[0.98]">
          Varaa etäpalaveri
        </a>
      </div>
      <div class="hidden lg:block" aria-hidden="true"></div>
    </div>
    <div class="hidden lg:block absolute inset-y-0 right-0 w-1/2 overflow-hidden">
      <Image src={heroImg} alt="LVI-suunnittelun hinta" loading="eager" class="absolute inset-0 w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-forest/30"></div>
      <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-forest to-transparent"></div>
    </div>
  </section>

  <!-- Wave -->
  <div class="bg-forest overflow-hidden leading-none -mt-px -mb-px">
    <svg viewBox="0 0 1440 72" preserveAspectRatio="none" class="w-full block h-10 lg:h-14" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,36 C240,72 480,0 720,36 C960,72 1200,0 1440,36 L1440,72 L0,72 Z" fill="#F4F0E8" />
    </svg>
  </div>

  <!-- Pääsisältö -->
  <section class="bg-cream py-12 lg:py-20">
    <div class="max-w-[1140px] mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 lg:gap-16 items-start">
      <div>

      <!-- Intro -->
      <span class="inline-flex rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-forest/8 text-forest/55 mb-7">Hintaopas</span>
      <h2 class="font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-5">LVI-suunnittelun hinta lyhyesti</h2>
      <p class="font-body text-sm text-[#1A1A1A]/65 leading-relaxed mb-4">
        LVI-suunnittelun hinta määräytyy ensisijaisesti kohteen koon, järjestelmävalintojen ja suunnittelun laajuuden mukaan. Uudiskohde ja saneeraus ovat eri hintaisia — saneerauksessa olemassa olevan tekniikan kartoitus lisää työtä.
      </p>
      <p class="font-body text-sm text-[#1A1A1A]/65 leading-relaxed mb-10">
        Alla esimerkkihinnat tyypillisimmille kohteille. Tarkka hinta selviää aina kohdekohtaisesti — pyydä tarjous ilmaisessa etäpalaverissa.
      </p>

      <!-- Hintaesimerkit -->
      <h2 class="font-heading text-[#1A1A1A] text-xl lg:text-2xl mb-6">Esimerkkihinnat</h2>
      <div class="space-y-4 mb-12">

        <!-- Omakotitalo -->
        <div class="p-6 bg-forest/4 ring-1 ring-forest/10 rounded-xl">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="font-heading text-[#1A1A1A] text-base">Omakotitalo / pientalo</h3>
            <span class="font-body text-sm font-semibold text-forest whitespace-nowrap">1 500 – 4 000 €</span>
          </div>
          <p class="font-body text-sm text-[#1A1A1A]/60 leading-relaxed mb-3">
            Uuden omakotitalon täydellinen LVI-suunnittelu sisältää lämmitysjärjestelmän, käyttövesijärjestelmän, viemäröinnin ja ilmanvaihdon suunnittelun.
          </p>
          <ul class="space-y-1.5">
            {[
              'Käyttövesi- ja viemärisuunnitelmat',
              'Ilmanvaihtosuunnitelma',
              'Lämmitysjärjestelmän valinta ja mitoitus',
              'Rakennusvalvonnan edellyttämät asiakirjat',
            ].map(item => (
              <li class="flex items-start gap-2 font-body text-[11px] text-[#1A1A1A]/55">
                <span class="mt-1.5 w-1 h-1 rounded-full bg-forest/40 shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Rivitalo / pienkerrostalo -->
        <div class="p-6 bg-forest/4 ring-1 ring-forest/10 rounded-xl">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="font-heading text-[#1A1A1A] text-base">Rivitalo / pienkerrostalo</h3>
            <span class="font-body text-sm font-semibold text-forest whitespace-nowrap">4 000 – 9 000 €</span>
          </div>
          <p class="font-body text-sm text-[#1A1A1A]/60 leading-relaxed">
            Useamman asunnon kohteissa hintaan vaikuttaa asuntomäärä, kellaritilojen ja yhteistilojen laajuus sekä mahdolliset erikoisratkaisut kuten BIM-tietomallinnus.
          </p>
        </div>

        <!-- Taloyhtiö / linjasaneeraus -->
        <div class="p-6 bg-forest/4 ring-1 ring-forest/10 rounded-xl">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="font-heading text-[#1A1A1A] text-base">Taloyhtiö / linjasaneeraus</h3>
            <span class="font-body text-sm font-semibold text-forest whitespace-nowrap">5 000 € →</span>
          </div>
          <p class="font-body text-sm text-[#1A1A1A]/60 leading-relaxed">
            Kerrostalon linjasaneerauksen LVI-suunnittelu on kokonaisvaltainen projekti. Hintaan vaikuttavat asuntomäärä, suunnitteluvaiheen kokoukset ja olemassa olevien piirustuksien tila.
          </p>
        </div>

        <!-- Toimitila -->
        <div class="p-6 bg-forest/4 ring-1 ring-forest/10 rounded-xl">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="font-heading text-[#1A1A1A] text-base">Toimitila / moduulirakentaminen</h3>
            <span class="font-body text-sm font-semibold text-forest whitespace-nowrap">Tarjouspohjainen</span>
          </div>
          <p class="font-body text-sm text-[#1A1A1A]/60 leading-relaxed">
            Toimitilakohteissa ja moduulirakentamisen projekteissa hinta määräytyy täysin kohteen vaatimusten mukaan. Pyydä tarjous etäpalaverissa.
          </p>
        </div>

      </div>

      <!-- Mistä hinta koostuu -->
      <h2 class="font-heading text-[#1A1A1A] text-xl lg:text-2xl mb-5">Mistä LVI-suunnittelun hinta koostuu</h2>
      <ul class="space-y-3 mb-10">
        {[
          { title: 'Suunnittelutyö', desc: 'Järjestelmien mitoitus, reititykset ja piirustukset. Suurin osa kokonaishinnasta.' },
          { title: 'Kohdekatselmus', desc: 'Olemassa olevan tekniikan kartoitus saneerauskohteissa.' },
          { title: 'Kokoukset', desc: 'Aloitus-, luonnos- ja toteutussuunnitelmien esittelypalaverit. Määrä vaihtelee projektin laajuuden mukaan.' },
          { title: 'Rakennusvalvonta-asiakirjat', desc: 'Leimaus rakennusvalvonnassa ja mahdolliset lisäselvitykset.' },
          { title: 'BIM-tietomallinnus', desc: 'Valinnainen lisä — 3D-suunnittelu AutoCAD/MagiCAD -ympäristössä.' },
        ].map(({ title, desc }) => (
          <li class="flex items-start gap-4">
            <span class="mt-1 w-1.5 h-1.5 rounded-full bg-forest/50 shrink-0"></span>
            <div>
              <span class="font-body text-sm font-semibold text-[#1A1A1A]">{title}</span>
              <span class="font-body text-sm text-[#1A1A1A]/60"> — {desc}</span>
            </div>
          </li>
        ))}
      </ul>

      <!-- Hinta-info boksit -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        <div class="p-5 bg-forest text-white rounded-xl">
          <p class="font-body text-[10px] tracking-[0.2em] uppercase text-white/40 mb-2">Muista</p>
          <p class="font-body text-sm text-white/75 leading-relaxed">
            LVI-suunnitelma on rakennuslupaan lakisääteisesti vaadittava asiakirja. Ilman sitä rakennuslupaa ei myönnetä.
          </p>
        </div>
        <div class="p-5 bg-forest/8 ring-1 ring-forest/12 rounded-xl">
          <p class="font-body text-[10px] tracking-[0.2em] uppercase text-[#1A1A1A]/35 mb-2">Vinkki</p>
          <p class="font-body text-sm text-[#1A1A1A]/65 leading-relaxed">
            Hinta on edullisempi teettää ajoissa. Kiireellisessä aikataulussa tai puutteellisten lähtötietojen kanssa lisätyöt nostavat kustannuksia.
          </p>
        </div>
      </div>

      </div>

      <!-- Sivupalkki -->
      <aside class="lg:sticky lg:top-28 h-fit space-y-6">
        <div class="bg-forest text-white p-6">
          <p class="font-body text-[10px] tracking-[0.16em] uppercase text-white/55 mb-4">LVI-suunnittelu</p>
          <p class="font-heading text-white text-lg leading-snug mb-1">Ilmainen tarjous</p>
          <p class="font-body text-[13px] text-white/55 leading-snug mb-4">KVV- ja IV-pätevyydet. BIM-tietomallinnus. Uudis- ja saneerauskohteet.</p>
          <div class="space-y-1.5 mb-5">
            {[
              'Omakotitalo 1 500–4 000 €',
              'Rivitalo 4 000–9 000 €',
              'Taloyhtiö 5 000 € →',
            ].map(p => (
              <p class="font-body text-[12px] text-white/50">{p}</p>
            ))}
          </div>
          <div class="border-t border-white/10 pt-5">
            <a href="#yhteydenotto" class="block w-full text-center font-body text-[11px] tracking-[0.16em] uppercase bg-white text-forest px-4 py-3 hover:bg-white/90 transition-colors active:scale-[0.98]">Pyydä tarjous</a>
          </div>
        </div>
        <div class="border border-[#1A1A1A]/8 p-5 space-y-3">
          <p class="font-body text-[10px] tracking-[0.16em] uppercase text-[#1A1A1A]/50 mb-4">Ota yhteyttä</p>
          <a href="tel:+358407656096" class="flex items-center gap-3 font-body text-sm text-[#1A1A1A]/65 hover:text-forest transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 text-forest/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            040 7656 096
          </a>
          <a href="mailto:oskari@vattu.fi" class="flex items-center gap-3 font-body text-sm text-[#1A1A1A]/65 hover:text-forest transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 text-forest/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            oskari@vattu.fi
          </a>
        </div>
        <div>
          <p class="font-body text-[10px] tracking-[0.16em] uppercase text-[#1A1A1A]/50 mb-3">Katso myös</p>
          <div class="space-y-1">
            {[
              { href: '/energiaselvitys-hinta', label: 'Energiaselvityksen hinta' },
              { href: '/energiatodistus-hinta', label: 'Energiatodistuksen hinta' },
              { href: '/patteriverkoston-tasapainotus', label: 'Patteriverkoston tasapainotus' },
            ].map(l => (
              <a href={l.href} class="flex items-center justify-between group font-body text-[12px] text-[#1A1A1A]/50 hover:text-forest py-2 border-b border-[#1A1A1A]/6 last:border-0 transition-colors">
                {l.label}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-[#1A1A1A]/20 group-hover:text-forest/50 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
              </a>
            ))}
          </div>
        </div>
      </aside>

      </div>
    </div>
  </section>

  <!-- Yhteydenotto -->
  <section id="yhteydenotto" class="bg-cream border-t border-[#1A1A1A]/8 py-12 lg:py-20 pb-24 lg:pb-20">
    <div class="max-w-[800px] mx-auto px-6 lg:px-12">
      <p class="font-body text-[10px] tracking-[0.22em] uppercase text-[#1A1A1A]/50 mb-3">Yhteydenotto</p>
      <h2 class="font-heading text-[#1A1A1A] text-2xl lg:text-3xl mb-3">Pyydä ilmainen tarjous</h2>
      <p class="font-body text-sm text-[#1A1A1A]/50 mb-8">Kerro projektin perustiedot — saat selkeän tarjouksen ilman sitoumuksia. Varaa 60 min etäpalaveri tai lähetä sähköpostia.</p>

      <div class="hidden lg:block border border-[#1A1A1A]/8 overflow-hidden shadow-sm mb-8">
        <div class="bg-forest/5 border-b border-[#1A1A1A]/8 px-5 py-3 flex items-center gap-3">
          <div class="w-2 h-2 rounded-full bg-forest/40"></div>
          <span class="font-body text-[11px] tracking-[0.14em] uppercase text-[#1A1A1A]/35">Ilmainen etäpalaveri 60 min</span>
        </div>
        <iframe src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0EiCYaQeHPOreKXBXVhRlFcn7Ag2rVd6PC4938WN1oFasif4wKNPu8jUwBSsfZKMKPWs0oqAld?gv=true" style="border:0;display:block;" width="100%" height="550" frameborder="0" title="Varaa etäpalaveri"></iframe>
      </div>
      <div class="lg:hidden mb-6">
        <a href="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0EiCYaQeHPOreKXBXVhRlFcn7Ag2rVd6PC4938WN1oFasif4wKNPu8jUwBSsfZKMKPWs0oqAld?gv=true" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between w-full bg-forest text-white px-6 py-5 active:scale-[0.98] transition-transform">
          <div>
            <p class="font-body text-[10px] tracking-[0.18em] uppercase text-white/50 mb-1">Ilmainen · 60 min · Google Meet</p>
            <p class="font-heading text-lg">Varaa etäpalaveri</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="tel:+358407656096" class="inline-flex items-center gap-3 font-body text-[11px] tracking-[0.16em] uppercase bg-forest text-white rounded-full px-6 py-3.5 hover:bg-forest/85 transition-colors active:scale-[0.97]">
          040 7656 096
        </a>
      </div>
    </div>
  </section>

</Layout>
